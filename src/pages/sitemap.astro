---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 1. Get all static pages automatically from the file system
const pageFiles = import.meta.glob('/src/pages/**/*.{astro,md,mdx}');
const filePaths = Object.keys(pageFiles)
  .filter((path) => {
    const fileName = path.split('/').pop() || '';
    // Exclude dynamic routes (starting with [), 404, private files, and utility endpoints
    return (
      !fileName.startsWith('[') &&
      !fileName.startsWith('_') &&
      !fileName.includes('404') &&
      !fileName.includes('sitemap') &&
      !fileName.includes('robots') &&
      !fileName.includes('rss')
    );
  })
  .map((path) => {
    // Remove /src/pages prefix and extension
    let route = path
      .replace('/src/pages', '')
      .replace(/\.(astro|md|mdx)$/, '');
    
    // Handle index routes
    if (route.endsWith('/index')) {
      route = route.replace('/index', '');
    }
    
    // Ensure root is just /
    if (route === '') return '/';
    return route;
  });

// 2. Define known dynamic regions (from [slug].astro) to ensure they are included
// even if physical files are missing.
const dynamicRegions = [
  'transformer-in-benin',
  'transformer-in-togo',
  'transformer-in-ghana',
  'transformer-in-uganda',
  'transformer-in-zimbabwe',
  'transformer-in-rwanda',
  'transformer-in-sierra-leone'
];

// 3. Combine and Deduplicate Paths
// We prioritize file paths, but add dynamic ones if missing
const allPathsSet = new Set(filePaths);
dynamicRegions.forEach(region => allPathsSet.add(`/${region}`));
const allPaths = Array.from(allPathsSet).sort();

// 4. Categorize Pages
const regionPages = allPaths.filter(path => path.includes('transformer-in-'));
const mainPages = allPaths.filter(path => 
  !path.includes('transformer-in-') && 
  !path.startsWith('/blog/') && // Exclude blog *posts* (handled separately) but keep /blog index
  path !== '/' // Home added manually
);

// 5. Get blog posts
const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Helper to format titles
function formatTitle(path: string) {
  if (path === '/') return 'Home';
  
  // Handle Transformer pages specifically for better formatting
  if (path.includes('transformer-in-')) {
    const country = path.replace('/transformer-in-', '').replace(/-/g, ' ');
    return `Transformers in ${country.charAt(0).toUpperCase() + country.slice(1)}`;
  }

  // General formatting
  const clean = path.replace(/^\//, '').replace(/[-_]/g, ' ');
  return clean.replace(/\b\w/g, c => c.toUpperCase());
}
---

<BaseLayout 
  title="Sitemap | Elsan Transformers" 
  description="Navigate through all pages, regional sections, and resources on the Elsan Transformers website."
>
  <div class="bg-gray-50 min-h-screen py-16 md:py-24" data-ps="src/pages/sitemap.astro:bqj62n">
    <div class="container mx-auto px-4 max-w-6xl" data-ps="src/pages/sitemap.astro:bqj62m">
      <div class="text-center mb-16" data-ps="src/pages/sitemap.astro:bqj62l">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4" data-ps="src/pages/sitemap.astro:p2s2jj">Sitemap</h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto" data-ps="src/pages/sitemap.astro:5kwcf3">
          Complete overview of our website structure, regional presence, and resources.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" data-ps="src/pages/sitemap.astro:bqj62k">
        <!-- Main Pages Column -->
        <div class="bg-white rounded-xl shadow-sm p-8 border border-gray-100 hover:shadow-md transition-shadow" data-ps="src/pages/sitemap.astro:bqj62j">
          <div class="flex items-center gap-3 mb-6 border-b border-gray-100 pb-4" data-ps="src/pages/sitemap.astro:bqj62i">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e85d1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <h2 class="text-2xl font-bold text-gray-800" data-ps="src/pages/sitemap.astro:aed5bw">Main Pages</h2>
          </div>
          <ul class="space-y-3">
            <li data-ps="src/pages/sitemap.astro:b5c1tj">
              <a href="/" class="flex items-center text-gray-600 hover:text-[#e85d1a] transition-colors group" data-ps="src/pages/sitemap.astro:1j1k9w">
                <span class="w-1.5 h-1.5 rounded-full bg-gray-300 group-hover:bg-[#e85d1a] mr-3 transition-colors" data-ps="src/pages/sitemap.astro:wi6hsa"></span>
                Home
              </a>
            </li>
            {mainPages.map((path) => (
              <li data-ps="src/pages/sitemap.astro:b5c1tk">
                <a href={path} class="flex items-center text-gray-600 hover:text-[#e85d1a] transition-colors group" data-ps="src/pages/sitemap.astro:1j1k9x">
                  <span class="w-1.5 h-1.5 rounded-full bg-gray-300 group-hover:bg-[#e85d1a] mr-3 transition-colors" data-ps="src/pages/sitemap.astro:wi6hs9"></span>
                  {formatTitle(path)}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Regional Presence Column -->
        <div class="bg-white rounded-xl shadow-sm p-8 border border-gray-100 hover:shadow-md transition-shadow" data-ps="src/pages/sitemap.astro:bqj62h">
          <div class="flex items-center gap-3 mb-6 border-b border-gray-100 pb-4" data-ps="src/pages/sitemap.astro:bqj62g">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e85d1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            <h2 class="text-2xl font-bold text-gray-800" data-ps="src/pages/sitemap.astro:aed5bx">Regional Presence</h2>
          </div>
          <ul class="space-y-3">
            {regionPages.map((path) => (
              <li data-ps="src/pages/sitemap.astro:b5c1tl">
                <a href={path} class="flex items-center text-gray-600 hover:text-[#e85d1a] transition-colors group" data-ps="src/pages/sitemap.astro:1j1k9y">
                  <span class="w-1.5 h-1.5 rounded-full bg-gray-300 group-hover:bg-[#e85d1a] mr-3 transition-colors" data-ps="src/pages/sitemap.astro:wi6hs8"></span>
                  {formatTitle(path)}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Blog/Resources Column -->
        <div class="bg-white rounded-xl shadow-sm p-8 border border-gray-100 hover:shadow-md transition-shadow" data-ps="src/pages/sitemap.astro:bqj62f">
          <div class="flex items-center gap-3 mb-6 border-b border-gray-100 pb-4" data-ps="src/pages/sitemap.astro:bqj62e">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e85d1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            <h2 class="text-2xl font-bold text-gray-800" data-ps="src/pages/sitemap.astro:aed5by">Latest Insights</h2>
          </div>
          <ul class="space-y-3">
            <li data-ps="src/pages/sitemap.astro:b5c1tm">
              <a href="/blog" class="font-medium text-[#e85d1a] hover:opacity-80 flex items-center mb-2" data-ps="src/pages/sitemap.astro:1j1k9z">
                View All Articles &rarr;
              </a>
            </li>
            {sortedPosts.length > 0 ? (
              sortedPosts.map((post) => (
                <li data-ps="src/pages/sitemap.astro:b5c1tn">
                  <a href={`/blog/${post.slug}`} class="flex items-start text-gray-600 hover:text-[#e85d1a] transition-colors group text-sm" data-ps="src/pages/sitemap.astro:1j1ka0">
                    <span class="w-1.5 h-1.5 rounded-full bg-gray-300 group-hover:bg-[#e85d1a] mr-3 mt-1.5 transition-colors flex-shrink-0" data-ps="src/pages/sitemap.astro:wi6hs7"></span>
                    <span class="line-clamp-2" data-ps="src/pages/sitemap.astro:wi6hs6">{post.data.title}</span>
                  </a>
                </li>
              ))
            ) : (
              <li class="text-gray-500 italic text-sm" data-ps="src/pages/sitemap.astro:cy2du">No articles available yet.</li>
            )}
          </ul>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
