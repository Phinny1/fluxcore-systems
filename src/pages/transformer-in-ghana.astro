---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';

const country = "Ghana";
---

<BaseLayout
  title={`Transformer in ${country} | Elsan Transformers`}
  description={`Premier transformer solutions and power infrastructure for ${country}.`}
>
  <PageHero 
    title={`Transformer in ${country}`}
    subtitle={`Powering ${country}'s grid with high-efficiency distribution and power transformers.`}
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/IMG-20260226-WA0075-640-640.webp"
  />
  
  <section class="py-16 bg-white" data-ps="src/pages/transformer-in-ghana.astro:section1">
    <div class="max-w-4xl mx-auto px-6" data-ps="src/pages/transformer-in-ghana.astro:hdtzpu">
      <div class="prose prose-lg max-w-none" data-ps="src/pages/transformer-in-ghana.astro:hdtzpt">
        <p class="text-xl text-slate-700 leading-relaxed mb-12" data-ps="src/pages/transformer-in-ghana.astro:2c8lhz">
          Elsan Transformer supplies certified power and distribution transformers to Ghana, manufactured in Turkey to IEC 60076 and ISO 9001:2015 standards, with export delivery coordinated to Tema port.
        </p>

        <h2 class="text-3xl font-bold text-slate-900 mb-6" data-ps="src/pages/transformer-in-ghana.astro:oi6ylt">Ghana's Electricity Sector and Transformer Requirements</h2>
        <p data-ps="src/pages/transformer-in-ghana.astro:2c8li0">
          Ghana operates one of West Africa's most developed electricity networks, managed by ECG (Electricity Company of Ghana) across the southern distribution zone and NEDCo (Northern Electricity Distribution Company) across the northern regions. The country's growing industrial base — spanning mining in the Ashanti and Western regions, manufacturing in Accra and Tema, and large-scale commercial development — creates consistent, high-volume demand for reliable transformer equipment that meets both Ghanaian grid code standards and international technical benchmarks.
        </p>

        <h2 class="text-3xl font-bold text-slate-900 mt-12 mb-6" data-ps="src/pages/transformer-in-ghana.astro:oi6yls">Elsan's Transformer Range for Ghana</h2>
        <p data-ps="src/pages/transformer-in-ghana.astro:2c8li1">Elsan supplies the full capacity range required by ECG, NEDCo, independent power producers, and engineering contractors across Ghana:</p>
        <ul class="space-y-4">
          <li data-ps="src/pages/transformer-in-ghana.astro:mf7pko"><strong>Distribution transformers:</strong> 25 kVA to 2,500 kVA — for ECG and NEDCo 11 kV and 33 kV distribution networks, in oil-immersed and dry-type options</li>
          <li data-ps="src/pages/transformer-in-ghana.astro:mf7pkp"><strong>Power transformers:</strong> 3.15 MVA to 50 MVA — for substation, transmission, and large industrial applications</li>
          <li data-ps="src/pages/transformer-in-ghana.astro:mf7pkq"><strong>Single-phase units:</strong> up to 160 kVA — for rural electrification under Ghana's national access programmes</li>
          <li data-ps="src/pages/transformer-in-ghana.astro:mf7pkr"><strong>Solar PV transformers:</strong> custom-engineered for Ghana's growing utility-scale and rooftop solar sector</li>
        </ul>

        <p class="mt-8" data-ps="src/pages/transformer-in-ghana.astro:2c8li2">
          Elsan's high-permeability grain-oriented silicon steel cores and precision copper windings deliver low no-load and load losses — critical for Ghana's technically demanding procurement processes. All units undergo comprehensive factory routine testing to IEC 60076 before dispatch, with full test documentation provided.
        </p>

        <h2 class="text-3xl font-bold text-slate-900 mt-12 mb-6" data-ps="src/pages/transformer-in-ghana.astro:oi6ylr">Standards, Certifications, and Quality</h2>
        <p data-ps="src/pages/transformer-in-ghana.astro:2c8li3">
          Elsan transformers are manufactured in full compliance with IEC 60076. The production facility is certified to ISO 9001:2015, ISO 14001, and ISO 45001. Routine test certificates, type test reports, and detailed technical datasheets accompany every order — satisfying ECG, NEDCo, and international lender requirements.
        </p>

        <div class="mt-16 pt-16 border-t border-slate-200" data-ps="src/pages/transformer-in-ghana.astro:hdtzpx">
          <h2 class="text-3xl font-bold text-slate-900 mb-8" data-ps="src/pages/transformer-in-ghana.astro:oi6ylq">Frequently Asked Questions</h2>
          
          <div class="space-y-8" data-ps="src/pages/transformer-in-ghana.astro:hdtzpw">
            <div data-ps="src/pages/transformer-in-ghana.astro:hdtzpv">
              <h3 class="text-xl font-bold text-slate-900 mb-3" data-ps="src/pages/transformer-in-ghana.astro:6ztvvd">How does Elsan deliver to Ghana?</h3>
              <p class="text-slate-600" data-ps="src/pages/transformer-in-ghana.astro:2c8li4">Units are exported from Nigeria with full documentation, coordinated to Tema port or project sites across Ghana.</p>
            </div>
            
            <div data-ps="src/pages/transformer-in-ghana.astro:hdtzpu">
              <h3 class="text-xl font-bold text-slate-900 mb-3" data-ps="src/pages/transformer-in-ghana.astro:6ztvve">What voltage classes are available?</h3>
              <p class="text-slate-600" data-ps="src/pages/transformer-in-ghana.astro:2c8li5">11 kV, 33 kV, and higher primary voltage configurations are available.</p>
            </div>
            
            <div data-ps="src/pages/transformer-in-ghana.astro:hdtzpt">
              <h3 class="text-xl font-bold text-slate-900 mb-3" data-ps="src/pages/transformer-in-ghana.astro:oz8lqq">Does Elsan work with mining operations?</h3>
              <p class="text-slate-600" data-ps="src/pages/transformer-in-ghana.astro:2c8li6">Yes — power transformers for continuous high-load mining applications are a key part of Elsan's Ghana supply portfolio.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <QuotationRequest />
</BaseLayout>
