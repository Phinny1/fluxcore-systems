---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import Specifications from '@/components/home/Specifications.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';
import Industries from '@/components/home/Industries.astro';
---

<BaseLayout
  title="Construction & Infrastructure | Elsan Transformer"
  description="Distribution transformers for construction sites and infrastructure projects, available in various configurations."
>
  <PageHero 
    title="Construction & Infrastructure" 
    subtitle="Powering development with reliable transformers for construction and permanent infrastructure."
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/IMG-20260226-WA0075-640-640.webp"
  />

  <section class="py-24 bg-white" data-ps="src/pages/construction-and-infrastructure.astro:hxxj48">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/construction-and-infrastructure.astro:n388td">
      <div class="grid md:grid-cols-2 gap-16 items-center" data-ps="src/pages/construction-and-infrastructure.astro:n388te">
        <div data-ps="src/pages/construction-and-infrastructure.astro:n388tf">
          <h2 class="text-4xl font-black tracking-tighter text-slate-900 mb-6 uppercase" data-ps="src/pages/construction-and-infrastructure.astro:kebtkq">Building the Future</h2>
          <p class="text-lg text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/construction-and-infrastructure.astro:z1gyan">
            Distribution transformers for construction projects and permanent infrastructure installations across Nigeria — available in pole-mounted, pad-mounted, and compact substation configurations. We ensure your sites have the power they need, when they need it.
          </p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3" data-ps="src/pages/construction-and-infrastructure.astro:7osxj8">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/construction-and-infrastructure.astro:cj2uta"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/construction-and-infrastructure.astro:cj2utb">Flexible mounting options (pole, pad, substation)</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/construction-and-infrastructure.astro:7osxj9">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/construction-and-infrastructure.astro:cj2utc"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/construction-and-infrastructure.astro:cj2utd">Quick deployment for temporary power needs</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/construction-and-infrastructure.astro:7osxjv">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/construction-and-infrastructure.astro:cj2ute"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/construction-and-infrastructure.astro:cj2utf">Durable designs for active construction sites</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/construction-and-infrastructure.astro:7osxjw">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/construction-and-infrastructure.astro:cj2utg"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/construction-and-infrastructure.astro:4zixms">Scalable solutions for large infrastructure projects</span>
            </li>
          </ul>
          <a href="/contact/" class="inline-block bg-[#E85D1A] text-slate-900 px-8 py-4 font-bold uppercase tracking-widest hover:bg-[#D04C0F] transition-colors" data-ps="src/pages/construction-and-infrastructure.astro:rwumdh">CONTACT US</a>
        </div>
        <div class="relative" data-ps="src/pages/construction-and-infrastructure.astro:n388tg">
          <img
            src="https://cdn.pagesmith.app/3ebbed7b/images/IMG-20260226-WA0075-640.webp"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Construction Crane" 
            class="w-full h-auto shadow-2xl" data-ps="src/pages/construction-and-infrastructure.astro:6s0ptx" />
          <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-[#E85D1A]/10 -z-10" data-ps="src/pages/construction-and-infrastructure.astro:n388th"></div>
        </div>
      </div>
    </div>
  </section>

  <Specifications />
  <Industries />
  <QuotationRequest />
</BaseLayout>
