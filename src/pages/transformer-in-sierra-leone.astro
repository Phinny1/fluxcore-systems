---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';

const country = "Sierra Leone";
---

<BaseLayout
  title={`Transformer in ${country} | Elsan Transformers`}
  description={`Premier transformer solutions and power infrastructure for ${country}.`}
>
  <PageHero 
    title={`Transformer in ${country}`}
    subtitle={`Powering ${country}'s grid with high-efficiency distribution and power transformers.`}
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/IMG-20260226-WA0075-640-640.webp"
  />
  
  <section class="py-16 bg-white" data-ps="src/pages/transformer-in-sierra-leone.astro:section1">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/transformer-in-sierra-leone.astro:lo84wj">
      <div class="prose max-w-none" data-ps="src/pages/transformer-in-sierra-leone.astro:lo84wk">
        <h2 class="text-3xl font-bold mb-6" data-ps="src/pages/transformer-in-sierra-leone.astro:bls6ey">Power Solutions for {country}</h2>
        <div class="text-lg text-slate-600 mb-8 space-y-6" data-ps="src/pages/transformer-in-sierra-leone.astro:d9jtf1">
          <p data-ps="src/pages/transformer-in-sierra-leone.astro:eylzwy">
            Elsan Transformer supplies certified power and distribution transformers to Sierra Leone, manufactured in Turkey to IEC 60076 and ISO 9001:2015 standards, with full export documentation and logistics to Freetown.
          </p>

          <h3 class="text-2xl font-semibold text-slate-900 mt-8 mb-4" data-ps="src/pages/transformer-in-sierra-leone.astro:b4qj9w">Sierra Leone's Electricity Sector and Transformer Requirements</h3>
          <p data-ps="src/pages/transformer-in-sierra-leone.astro:eylzwz">
            Sierra Leone's electricity infrastructure is managed by EDSA (Electricity Distribution and Supply Authority) for distribution and EGTC (Electricity Generation and Transmission Company) for generation and transmission. The national grid is centred on Freetown and the Western Area, with provincial coverage in Bo, Kenema, Makeni, and Koidu. EWRC (Electricity and Water Regulatory Commission) governs technical standards. Financing from the World Bank, African Development Bank, European Investment Bank, and bilateral donors actively supports Sierra Leone's grid expansion — making certified, documentation-rich transformer supply essential for project compliance.
          </p>

          <h3 class="text-2xl font-semibold text-slate-900 mt-8 mb-4" data-ps="src/pages/transformer-in-sierra-leone.astro:b4qj9x">Elsan's Transformer Range for Sierra Leone</h3>
          <p data-ps="src/pages/transformer-in-sierra-leone.astro:eylzx0">
            Elsan supplies the full range of transformer types required by EDSA, EGTC, EPC contractors, and development-financed project teams across Sierra Leone:
          </p>
          <ul class="list-disc pl-6 space-y-2">
            <li data-ps="src/pages/transformer-in-sierra-leone.astro:5co5gz"><strong>Distribution transformers:</strong> 25 kVA to 2,500 kVA — for EDSA's 11 kV and 33 kV distribution network in pole-mounted, pad-mounted, and packaged substation configurations</li>
            <li data-ps="src/pages/transformer-in-sierra-leone.astro:5co5h0"><strong>Power transformers:</strong> 3.15 MVA to 50 MVA — for grid infrastructure and major substation construction</li>
            <li data-ps="src/pages/transformer-in-sierra-leone.astro:5co5h1"><strong>Single-phase units:</strong> up to 160 kVA — for rural electrification across provincial and chiefdom communities</li>
            <li data-ps="src/pages/transformer-in-sierra-leone.astro:5co5h2"><strong>Solar PV transformers:</strong> engineered for off-grid and hybrid solar installations across unelectrified regions</li>
          </ul>

          <p data-ps="src/pages/transformer-in-sierra-leone.astro:eylzx1">
            Sierra Leone's equatorial coastal climate — high humidity exceeding 80%, heavy seasonal rainfall reaching 3,000 mm annually in Freetown, and salt air corrosion in coastal zones — demands hermetically sealed tanks, tropical-grade transformer oil, and corrosion-resistant exterior coatings. Elsan specifies all units for this environment as standard. Full factory routine testing to IEC 60076 is completed before dispatch.
          </p>

          <h3 class="text-2xl font-semibold text-slate-900 mt-8 mb-4" data-ps="src/pages/transformer-in-sierra-leone.astro:b4qj9y">Standards, Certifications, and Documentation</h3>
          <p data-ps="src/pages/transformer-in-sierra-leone.astro:eylzx2">
            Elsan holds ISO 9001:2015, ISO 14001, and ISO 45001 certification. All products comply with IEC 60076. Routine test certificates, type test reports, and technical datasheets are provided — meeting EWRC, EDSA procurement requirements, and World Bank, AfDB, and EIB documentation standards.
          </p>

          <div class="mt-12 bg-slate-50 p-8 rounded-2xl border border-slate-100" data-ps="src/pages/transformer-in-sierra-leone.astro:lo84wg">
            <h3 class="text-2xl font-semibold text-slate-900 mb-6" data-ps="src/pages/transformer-in-sierra-leone.astro:b4qj9z">Frequently Asked Questions</h3>
            <div class="space-y-6" data-ps="src/pages/transformer-in-sierra-leone.astro:lo84wh">
              <div data-ps="src/pages/transformer-in-sierra-leone.astro:lo84wi">
                <h4 class="text-lg font-bold text-slate-900" data-ps="src/pages/transformer-in-sierra-leone.astro:or4lfw">Does Elsan export to Freetown?</h4>
                <p class="text-slate-600 mt-2" data-ps="src/pages/transformer-in-sierra-leone.astro:eylzx3">Yes — Combined road + sea freight from Nigeria to Freetown with full customs documentation.</p>
              </div>
              <div data-ps="src/pages/transformer-in-sierra-leone.astro:lo84wj">
                <h4 class="text-lg font-bold text-slate-900" data-ps="src/pages/transformer-in-sierra-leone.astro:or4lfv">Are transformers rated for Sierra Leone's coastal humidity?</h4>
                <p class="text-slate-600 mt-2" data-ps="src/pages/transformer-in-sierra-leone.astro:eylzx4">Yes — sealed, tropical-rated construction is standard.</p>
              </div>
              <div data-ps="src/pages/transformer-in-sierra-leone.astro:lo84wk">
                <h4 class="text-lg font-bold text-slate-900" data-ps="src/pages/transformer-in-sierra-leone.astro:anow4z">What development finance documentation is available?</h4>
                <p class="text-slate-600 mt-2" data-ps="src/pages/transformer-in-sierra-leone.astro:eylzx5">IEC 60076 test reports, ISO 9001 certificates, and full factory test protocols.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <QuotationRequest />
</BaseLayout>
