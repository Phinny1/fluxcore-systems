---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';

const country = "Zimbabwe";
---

<BaseLayout
  title={`Transformer in ${country} | Elsan Transformers`}
  description={`Premier transformer solutions and power infrastructure for ${country}.`}
>
  <PageHero 
    title={`Transformer in ${country}`}
    subtitle={`Powering ${country}'s grid with high-efficiency distribution and power transformers.`}
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/IMG-20260226-WA0075-640-640.webp"
  />
  
  <section class="py-16 bg-white" data-ps="src/pages/transformer-in-zimbabwe.astro:section1">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/transformer-in-zimbabwe.astro:we525q">
      <div class="prose max-w-none" data-ps="src/pages/transformer-in-zimbabwe.astro:we525p">
        <h2 class="text-3xl font-bold mb-6" data-ps="src/pages/transformer-in-zimbabwe.astro:url649">Power Solutions for {country}</h2>
        <p class="text-lg text-slate-600 mb-8" data-ps="src/pages/transformer-in-zimbabwe.astro:p2koq6">
          Elsan Transformer supplies certified power and distribution transformers to Zimbabwe, manufactured in Turkey to IEC 60076 and ISO 9001:2015 standards, with export logistics via Beit Bridge and Plumtree border crossings.
        </p>

        <h3 class="text-2xl font-bold mt-12 mb-4" data-ps="src/pages/transformer-in-zimbabwe.astro:h3-1">Zimbabwe's Electricity Sector and Transformer Requirements</h3>
        <p class="text-slate-600 mb-6" data-ps="src/pages/transformer-in-zimbabwe.astro:p-sector">
          Zimbabwe's electricity infrastructure is managed by ZETDC (Zimbabwe Electricity Transmission and Distribution Company) for distribution and ZESA Holdings as the parent utility entity. The country's generation capacity — centred on Hwange Thermal Power Station, Kariba South Hydro, and expanding renewable energy projects — feeds a distribution network serving Harare, Bulawayo, Mutare, Gweru, and industrial zones across the Midlands and Matabeleland regions. ZERA (Zimbabwe Energy Regulatory Authority) governs technical standards for all grid equipment, including transformers. Decades of deferred maintenance have created significant demand for transformer replacements and substation upgrades across ZETDC's network.
        </p>

        <h3 class="text-2xl font-bold mt-12 mb-4" data-ps="src/pages/transformer-in-zimbabwe.astro:h3-range">Elsan's Transformer Range for Zimbabwe</h3>
        <p class="text-slate-600 mb-6" data-ps="src/pages/transformer-in-zimbabwe.astro:p-range-intro">
          Elsan supplies the full capacity range required across Zimbabwe's utility rehabilitation and industrial sectors:
        </p>
        <ul class="list-disc pl-6 mb-8 text-slate-600 space-y-2" data-ps="src/pages/transformer-in-zimbabwe.astro:ul-range">
          <li data-ps="src/pages/transformer-in-zimbabwe.astro:h1j6s2"><strong>Distribution transformers:</strong> 25 kVA to 2,500 kVA — for ZETDC's 11 kV and 33 kV medium-voltage network in oil-immersed, ONAN-cooled configurations</li>
          <li data-ps="src/pages/transformer-in-zimbabwe.astro:h1j6s3"><strong>Power transformers:</strong> 3.15 MVA to 50 MVA — with OLTC and ONAF/OFAF cooling for substation reconstruction and grid reinforcement</li>
          <li data-ps="src/pages/transformer-in-zimbabwe.astro:h1j6s4"><strong>Single-phase units:</strong> up to 160 kVA — for rural electrification under Zimbabwe's REA programmes</li>
          <li data-ps="src/pages/transformer-in-zimbabwe.astro:h1j6s5"><strong>Solar PV transformers:</strong> custom-engineered for Zimbabwe's growing solar IPP and off-grid sector</li>
        </ul>

        <p class="text-slate-600 mb-6" data-ps="src/pages/transformer-in-zimbabwe.astro:p-altitude">
          Zimbabwe's highveld terrain — at 1,200 to 1,800 metres elevation — and its lowveld regions with high ambient temperatures demand transformers with altitude-corrected insulation and robust thermal performance. Elsan's engineering team applies IEC 60076 altitude correction factors during specification to ensure compliant operation across all of Zimbabwe's geographic zones. All units are factory tested before dispatch.
        </p>

        <h3 class="text-2xl font-bold mt-12 mb-4" data-ps="src/pages/transformer-in-zimbabwe.astro:h3-standards">Standards, Certifications, and Documentation</h3>
        <p class="text-slate-600 mb-12" data-ps="src/pages/transformer-in-zimbabwe.astro:p-standards">
          Elsan holds ISO 9001:2015, ISO 14001, and ISO 45001 certification. All products comply with IEC 60076. Full routine test certificates, type test reports, and technical datasheets are provided — meeting ZERA technical requirements and the documentation standards of international project finance lenders.
        </p>

        <div class="bg-slate-50 p-8 rounded-2xl border border-slate-100 mt-16" data-ps="src/pages/transformer-in-zimbabwe.astro:faq-container">
          <h2 class="text-3xl font-bold mb-8" data-ps="src/pages/transformer-in-zimbabwe.astro:faq-title">Frequently Asked Questions</h2>
          
          <div class="space-y-8" data-ps="src/pages/transformer-in-zimbabwe.astro:faq-list">
            <div data-ps="src/pages/transformer-in-zimbabwe.astro:faq-q1">
              <h3 class="text-xl font-semibold mb-3" data-ps="src/pages/transformer-in-zimbabwe.astro:uajizd">How does Elsan supply to Zimbabwe?</h3>
              <p class="text-slate-600" data-ps="src/pages/transformer-in-zimbabwe.astro:p2koq8">Via Beit Bridge or Plumtree with full export and Zimbabwean customs documentation.</p>
            </div>

            <div data-ps="src/pages/transformer-in-zimbabwe.astro:faq-q2">
              <h3 class="text-xl font-semibold mb-3" data-ps="src/pages/transformer-in-zimbabwe.astro:uajize">Are altitude-derated transformers available?</h3>
              <p class="text-slate-600" data-ps="src/pages/transformer-in-zimbabwe.astro:p2koq7">Yes — highveld and lowveld specifications are both supported.</p>
            </div>

            <div data-ps="src/pages/transformer-in-zimbabwe.astro:faq-q3">
              <h3 class="text-xl font-semibold mb-3" data-ps="src/pages/transformer-in-zimbabwe.astro:uajizf">Can Elsan supply the mining sector?</h3>
              <p class="text-slate-600" data-ps="src/pages/transformer-in-zimbabwe.astro:p2koq6">Yes — high-load, OLTC-equipped power transformers are available for platinum, gold, and chrome mining operations.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <QuotationRequest />
</BaseLayout>
