---
import { SITE } from '@/config/site';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/home/Hero.astro';
import Features from '@/components/home/Features.astro';
import About from '@/components/home/About.astro';
import Products from '@/components/home/Products.astro';
import Industries from '@/components/home/Industries.astro';
import Specifications from '@/components/home/Specifications.astro';
import FAQ from '@/components/home/FAQ.astro';
import Contact from '@/components/home/Contact.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';
---

<BaseLayout
  title="Elsan Transformer | Power & Distribution Transformer Manufacturer"
  description="IEC 60076-certified power & distribution transformers from Turkey. 25 kVA – 50 MVA. Supplying Nigeria's utilities, DISCOs & industry. Request a quote today."
  type="website"
  ogType="website"
  noIndex={false}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Elsan Transformer",
    "url": "https://www.elsantransformer.com.ng",
    "logo": "https://www.elsantransformer.com.ng/favicon.svg",
    "description": "Turkish manufacturer of IEC 60076-certified power and distribution transformers (25 kVA – 50 MVA) for Nigeria and West Africa.",
    "telephone": "+2348033142634",
    "email": "sales@elsantransformer.com",
    "address": [
      {
        "@type": "PostalAddress",
        "streetAddress": "Suite 17/18, Tian Plaza, Utako",
        "addressLocality": "Abuja",
        "addressCountry": "NG"
      },
      {
        "@type": "PostalAddress",
        "streetAddress": "Shop H1, Century Mall, Gudu",
        "addressLocality": "Abuja",
        "addressCountry": "NG"
      },
      {
        "@type": "PostalAddress",
        "streetAddress": "No. 10 Dauda Street, Ojo",
        "addressLocality": "Lagos",
        "addressCountry": "NG"
      }
    ],
    "areaServed": ["Nigeria", "Ghana", "Togo", "Benin", "Uganda", "West Africa"]
  }}>
  <Hero />
  <Features />
  <About />
  <Products />
  <Industries />
  <Specifications />
  <Contact />
  <FAQ />
  <QuotationRequest />
</BaseLayout>
