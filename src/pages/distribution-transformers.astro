---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import Specifications from '@/components/home/Specifications.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';
import Industries from '@/components/home/Industries.astro';
---

<BaseLayout
  title="Distribution Transformers | Elsan Transformer"
  description="High-efficiency distribution transformers for reliable power delivery in residential, commercial, and industrial networks."
>
  <PageHero 
    title="Distribution Transformers" 
    subtitle="Engineered for efficiency and long-term reliability in urban and rural distribution networks."
    backgroundImage="https://images.unsplash.com/photo-1765706836783-e9ad4db6fb53?auto=format&w=1200&q=80"
  />

  <section class="py-24 bg-white" data-ps="src/pages/distribution-transformers.astro:1">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/distribution-transformers.astro:xsr5t9">
      <div class="grid md:grid-cols-2 gap-16 items-center" data-ps="src/pages/distribution-transformers.astro:xsr5t8">
        <div data-ps="src/pages/distribution-transformers.astro:xsr5t7">
          <h2 class="text-4xl font-black tracking-tighter text-slate-900 mb-6 uppercase" data-ps="src/pages/distribution-transformers.astro:e8y0nb">Grid Ready Distribution</h2>
          <p class="text-lg text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/distribution-transformers.astro:g6akha">
            Our distribution transformers are designed to meet the rigorous demands of modern electrical grids. Available in both oil-immersed and dry-type configurations, these units provide seamless voltage step-down for end-user consumption.
          </p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3" data-ps="src/pages/distribution-transformers.astro:ernbn1">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/distribution-transformers.astro:oba5mb"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/distribution-transformers.astro:oba5ma">Ratings from 50kVA to 2500kVA</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/distribution-transformers.astro:ernbmf">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/distribution-transformers.astro:oba5m9"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/distribution-transformers.astro:oba5m8">High-grade silicon steel cores for low losses</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/distribution-transformers.astro:ernbme">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/distribution-transformers.astro:oba5m7"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/distribution-transformers.astro:oba5m6">Corrosion-resistant tank coatings for longevity</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/distribution-transformers.astro:ernbmd">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/distribution-transformers.astro:t03p12"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/distribution-transformers.astro:t03p13">Compliance with international IEC and ANSI standards</span>
            </li>
          </ul>
          <a href="/contact/" class="inline-block bg-[#E85D1A] text-slate-900 px-8 py-4 font-bold uppercase tracking-widest hover:bg-[#D04C0F] transition-colors" data-ps="src/pages/distribution-transformers.astro:2wmnro">CONTACT US</a>
        </div>
        <div class="relative" data-ps="src/pages/distribution-transformers.astro:xsr5t6">
          <img
            src="https://cdn.pagesmith.app/3ebbed7b/images/Elsan-Transformer-11-1024.webp" 
            alt="Industrial Distribution Transformer" 
            class="w-full h-auto shadow-2xl" data-ps="src/pages/distribution-transformers.astro:7d3xim" />
          <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-[#E85D1A]/10 -z-10" data-ps="src/pages/distribution-transformers.astro:xsr5t5"></div>
        </div>
      </div>
    </div>
  </section>

  <Specifications />
  <Industries />
  <QuotationRequest />
</BaseLayout>
