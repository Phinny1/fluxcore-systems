---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import Specifications from '@/components/home/Specifications.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';
import Industries from '@/components/home/Industries.astro';
---

<BaseLayout
  title="Oil, Gas & Petrochemical | Elsan Transformer"
  description="Hazardous area transformers for the oil, gas, and petrochemical sectors, meeting stringent safety standards."
>
  <PageHero 
    title="Oil, Gas & Petrochemical" 
    subtitle="Safety-critical power solutions for hazardous environments and processing plants."
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/IMG-20260226-WA0077-768-768-768.webp"
  />

  <section class="py-24 bg-white" data-ps="src/pages/oil-gas-and-petrochemical.astro:6osz44">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/oil-gas-and-petrochemical.astro:58ymc3">
      <div class="grid md:grid-cols-2 gap-16 items-center" data-ps="src/pages/oil-gas-and-petrochemical.astro:58ymc2">
        <div data-ps="src/pages/oil-gas-and-petrochemical.astro:58ymc1">
          <h2 class="text-4xl font-black tracking-tighter text-slate-900 mb-6 uppercase" data-ps="src/pages/oil-gas-and-petrochemical.astro:gtp3ki">Safety Critical Power</h2>
          <p class="text-lg text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/oil-gas-and-petrochemical.astro:4woadx">
            Transformers meeting stringent safety and reliability standards for Nigeria's oil and gas sector — suitable for hazardous area applications and process plant environments. We prioritize safety and compliance in every unit we manufacture.
          </p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3" data-ps="src/pages/oil-gas-and-petrochemical.astro:p3slfc">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/oil-gas-and-petrochemical.astro:lahj2m"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/oil-gas-and-petrochemical.astro:lahj2l">Explosion-proof and hazardous area designs</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/oil-gas-and-petrochemical.astro:p3slfd">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/oil-gas-and-petrochemical.astro:lahj2k"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/oil-gas-and-petrochemical.astro:lahj2j">Corrosion-resistant for offshore applications</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/oil-gas-and-petrochemical.astro:p3slfz">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/oil-gas-and-petrochemical.astro:lahj2i"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/oil-gas-and-petrochemical.astro:lahj2h">High reliability for critical process continuity</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/oil-gas-and-petrochemical.astro:p3slg0">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/oil-gas-and-petrochemical.astro:lahj2g"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/oil-gas-and-petrochemical.astro:nllm5s">Strict adherence to petrochemical industry standards</span>
            </li>
          </ul>
          <a href="/contact/" class="inline-block bg-[#E85D1A] text-slate-900 px-8 py-4 font-bold uppercase tracking-widest hover:bg-[#D04C0F] transition-colors" data-ps="src/pages/oil-gas-and-petrochemical.astro:2yqx6v">CONTACT US</a>
        </div>
        <div class="relative" data-ps="src/pages/oil-gas-and-petrochemical.astro:58ymc0">
          <img
            src="https://cdn.pagesmith.app/3ebbed7b/images/IMG-20260226-WA0077-768-768.webp"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Oil Refinery" 
            class="w-full h-auto shadow-2xl" data-ps="src/pages/oil-gas-and-petrochemical.astro:z47kzd" />
          <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-[#E85D1A]/10 -z-10" data-ps="src/pages/oil-gas-and-petrochemical.astro:58ymbz"></div>
        </div>
      </div>
    </div>
  </section>

  <Specifications />
  <Industries />
  <QuotationRequest />
</BaseLayout>
