---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';

const country = "Côte d'Ivoire";
---

<BaseLayout
  title={`Transformer in ${country} | Elsan Transformers`}
  description={`Premier transformer solutions and power infrastructure for ${country}.`}
>
  <PageHero 
    title={`Transformer in ${country}`}
    subtitle={`Powering ${country}'s grid with high-efficiency distribution and power transformers.`}
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/IMG-20260226-WA0075-640-640.webp"
  />
  
  <section class="py-16 bg-white" data-ps="src/pages/transformer-in-cote-divoire.astro:section1">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/transformer-in-cote-divoire.astro:hdtzpu">
      <div class="prose max-w-none prose-slate prose-lg" data-ps="src/pages/transformer-in-cote-divoire.astro:hdtzpt">
        <p class="lead" data-ps="src/pages/transformer-in-cote-divoire.astro:tqd301">
          Elsan Transformer supplies certified power and distribution transformers to Côte d'Ivoire, manufactured in Turkey to IEC 60076 and ISO 9001:2015 standards, with CIF export logistics to Abidjan.
        </p>

        <h2 class="text-3xl font-bold mt-12 mb-6 text-slate-900" data-ps="src/pages/transformer-in-cote-divoire.astro:oi6yln">Côte d'Ivoire's Electricity Sector and Transformer Demand</h2>
        <p data-ps="src/pages/transformer-in-cote-divoire.astro:tqd300">
          Côte d'Ivoire operates the most developed electricity market in Francophone West Africa. CIE (Compagnie Ivoirienne d'Electricité) manages national distribution across Abidjan, Bouaké, Yamoussoukro, San-Pédro, and regional networks, while CI-Energies oversees transmission and grid operations. The country's growing status as a regional electricity exporter — supplying power to Ghana, Mali, Burkina Faso, and Benin — combined with expansion in cocoa processing, mining, petroleum refining, and commercial real estate, drives consistent demand for technically sophisticated, efficient transformer equipment.
        </p>

        <h2 class="text-3xl font-bold mt-12 mb-6 text-slate-900" data-ps="src/pages/transformer-in-cote-divoire.astro:obaah3">Elsan's Transformer Range for Côte d'Ivoire</h2>
        <p data-ps="src/pages/transformer-in-cote-divoire.astro:tqd2zz">Elsan supplies the full transformer capacity range required across Côte d'Ivoire's grid and industrial sectors:</p>
        <ul class="list-disc pl-6 space-y-2">
          <li data-ps="src/pages/transformer-in-cote-divoire.astro:sdchm8"><strong>Distribution transformers:</strong> 25 kVA to 2,500 kVA — for CIE's 15 kV, 30 kV, and 33 kV networks, with high-permeability cores minimising no-load losses for an efficiency-focused market</li>
          <li data-ps="src/pages/transformer-in-cote-divoire.astro:sdchm9"><strong>Power transformers:</strong> 3.15 MVA to 50 MVA — with OLTC and advanced ONAF/OFAF cooling for substation and transmission applications</li>
          <li data-ps="src/pages/transformer-in-cote-divoire.astro:sdchma"><strong>Single-phase units:</strong> up to 160 kVA — for rural electrification under Côte d'Ivoire's national access programmes</li>
          <li data-ps="src/pages/transformer-in-cote-divoire.astro:sdchmw"><strong>Solar PV transformers:</strong> custom-engineered for utility-scale and industrial renewable energy projects</li>
        </ul>

        <p class="mt-8" data-ps="src/pages/transformer-in-cote-divoire.astro:tqd2zy">
          Precision copper windings, grain-oriented silicon steel cores, and sealed oil-immersed construction ensure Elsan transformers operate at peak efficiency across the full load range under Côte d'Ivoire's tropical ambient conditions. Every unit is factory tested to IEC 60076 and dispatched with complete routine test documentation.
        </p>

        <h2 class="text-3xl font-bold mt-12 mb-6 text-slate-900" data-ps="src/pages/transformer-in-cote-divoire.astro:obaah2">Standards, Certifications, and Quality Assurance</h2>
        <p data-ps="src/pages/transformer-in-cote-divoire.astro:tqd2zx">
          Elsan manufactures to IEC 60076 and operates under ISO 9001:2015, ISO 14001, and ISO 45001 certification. Routine test certificates, type test reports, and technical datasheets accompany all orders — meeting CIE, CI-Energies, and international lender technical qualification requirements.
        </p>

        <div class="mt-16 bg-slate-50 p-8 rounded-2xl border border-slate-200" data-ps="src/pages/transformer-in-cote-divoire.astro:oy21n8">
          <h2 class="text-2xl font-bold mb-8 text-slate-900" data-ps="src/pages/transformer-in-cote-divoire.astro:obaah1">Frequently Asked Questions</h2>
          <div class="space-y-8" data-ps="src/pages/transformer-in-cote-divoire.astro:oy21n9">
            <div data-ps="src/pages/transformer-in-cote-divoire.astro:oy21na">
              <h3 class="text-lg font-bold text-slate-900 mb-2" data-ps="src/pages/transformer-in-cote-divoire.astro:cxynwx">Does Elsan export to Côte d'Ivoire?</h3>
              <p class="text-slate-600" data-ps="src/pages/transformer-in-cote-divoire.astro:tqd2zw">Yes — CIF delivery to Abidjan with full export and customs documentation.</p>
            </div>
            <div data-ps="src/pages/transformer-in-cote-divoire.astro:oy21nb">
              <h3 class="text-lg font-bold text-slate-900 mb-2" data-ps="src/pages/transformer-in-cote-divoire.astro:osbxm1">Are Elsan transformers suitable for the 15 kV Ivorian network?</h3>
              <p class="text-slate-600" data-ps="src/pages/transformer-in-cote-divoire.astro:tqd2zv">Yes — 15 kV, 30 kV, and 33 kV primary configurations are all available.</p>
            </div>
            <div data-ps="src/pages/transformer-in-cote-divoire.astro:oy21nc">
              <h3 class="text-lg font-bold text-slate-900 mb-2" data-ps="src/pages/transformer-in-cote-divoire.astro:osbxm0">Can industrial mining or processing specifications be met?</h3>
              <p class="text-slate-600" data-ps="src/pages/transformer-in-cote-divoire.astro:tqd2zu">Yes — custom engineering for high-load industrial applications is a core capability.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <QuotationRequest />
</BaseLayout>
