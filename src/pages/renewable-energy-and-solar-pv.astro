---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import Specifications from '@/components/home/Specifications.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';
import Industries from '@/components/home/Industries.astro';
---

<BaseLayout
  title="Renewable Energy & Solar PV | Elsan Transformer"
  description="Specialized transformers for solar PV and renewable energy applications, supporting off-grid and hybrid systems."
>
  <PageHero 
    title="Renewable Energy & Solar PV" 
    subtitle="Sustainable power solutions for a greener future, optimized for solar and renewable integration."
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/Elsan-Transformer-7-1024-1024.webp"
  />

  <section class="py-24 bg-white" data-ps="src/pages/renewable-energy-and-solar-pv.astro:ckip8a">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/renewable-energy-and-solar-pv.astro:b95vo1">
      <div class="grid md:grid-cols-2 gap-16 items-center" data-ps="src/pages/renewable-energy-and-solar-pv.astro:b95vo0">
        <div data-ps="src/pages/renewable-energy-and-solar-pv.astro:b95vnz">
          <h2 class="text-4xl font-black tracking-tighter text-slate-900 mb-6 uppercase" data-ps="src/pages/renewable-energy-and-solar-pv.astro:pgjzn0">Solar & Renewable Integration</h2>
          <p class="text-lg text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/renewable-energy-and-solar-pv.astro:w86165">
            Custom-engineered solar and photovoltaic transformers for Nigeria's rapidly growing renewable energy sector, including off-grid and hybrid power systems. Our transformers are designed to handle the unique characteristics of solar inverters and variable generation.
          </p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3" data-ps="src/pages/renewable-energy-and-solar-pv.astro:7606h6">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/renewable-energy-and-solar-pv.astro:7aymmo"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/renewable-energy-and-solar-pv.astro:7aymmn">Multi-winding designs for multiple inverters</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/renewable-energy-and-solar-pv.astro:7606h5">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/renewable-energy-and-solar-pv.astro:7aymmm"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/renewable-energy-and-solar-pv.astro:7aymml">Electrostatic shielding for noise reduction</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/renewable-energy-and-solar-pv.astro:7606gj">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/renewable-energy-and-solar-pv.astro:7aymmk"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/renewable-energy-and-solar-pv.astro:7aymmj">High efficiency for maximum energy yield</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/renewable-energy-and-solar-pv.astro:7606gi">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/renewable-energy-and-solar-pv.astro:7aymmi"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/renewable-energy-and-solar-pv.astro:tjuryq">Designed for harsh outdoor solar farm conditions</span>
            </li>
          </ul>
          <a href="/contact/" class="inline-block bg-[#E85D1A] text-slate-900 px-8 py-4 font-bold uppercase tracking-widest hover:bg-[#D04C0F] transition-colors" data-ps="src/pages/renewable-energy-and-solar-pv.astro:bpk5h3">CONTACT US</a>
        </div>
        <div class="relative" data-ps="src/pages/renewable-energy-and-solar-pv.astro:b95vny">
          <img
            src="https://cdn.pagesmith.app/3ebbed7b/images/Elsan-Transformer-7-1024.webp"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Solar Farm" 
            class="w-full h-auto shadow-2xl" data-ps="src/pages/renewable-energy-and-solar-pv.astro:twp7nt" />
          <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-[#E85D1A]/10 -z-10" data-ps="src/pages/renewable-energy-and-solar-pv.astro:b95vnx"></div>
        </div>
      </div>
    </div>
  </section>

  <Specifications />
  <Industries />
  <QuotationRequest />
</BaseLayout>
