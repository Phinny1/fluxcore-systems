---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import Specifications from '@/components/home/Specifications.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';
import Industries from '@/components/home/Industries.astro';
---

<BaseLayout
  title="Electrical Utilities & Discos | Elsan Transformer"
  description="Reliable transformers for electricity distribution companies and state utilities, engineered for continuous grid demand."
>
  <PageHero 
    title="Electrical Utilities & Discos" 
    subtitle="Powering the grid with high-performance transformers built for stability and efficiency."
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/Elsan-Transformer-5-1024-1024.webp"
  />

  <section class="py-24 bg-white" data-ps="src/pages/electrical-utilities-and-discos.astro:t3mfti">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/electrical-utilities-and-discos.astro:vnoqpr">
      <div class="grid md:grid-cols-2 gap-16 items-center" data-ps="src/pages/electrical-utilities-and-discos.astro:vnoqps">
        <div data-ps="src/pages/electrical-utilities-and-discos.astro:vnoqpt">
          <h2 class="text-4xl font-black tracking-tighter text-slate-900 mb-6 uppercase" data-ps="src/pages/electrical-utilities-and-discos.astro:ie5vto">Grid Stability Solutions</h2>
          <p class="text-lg text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/electrical-utilities-and-discos.astro:ruva9v">
            We supply Electricity Distribution Companies (DISCOs) and state utilities across Nigeria with distribution and power transformers built for continuous grid demand. Our units are designed to withstand voltage fluctuations and ensure reliable power delivery to end-users.
          </p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3" data-ps="src/pages/electrical-utilities-and-discos.astro:177256">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/electrical-utilities-and-discos.astro:ertuqo"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/electrical-utilities-and-discos.astro:ertuqn">High reliability for continuous duty cycles</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/electrical-utilities-and-discos.astro:177255">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/electrical-utilities-and-discos.astro:ertuqm"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/electrical-utilities-and-discos.astro:ertuql">Designed for low losses and high efficiency</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/electrical-utilities-and-discos.astro:17724j">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/electrical-utilities-and-discos.astro:ertuqk"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/electrical-utilities-and-discos.astro:ertuqj">Robust construction for outdoor substations</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/electrical-utilities-and-discos.astro:17724i">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/electrical-utilities-and-discos.astro:ertuqi"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/electrical-utilities-and-discos.astro:h5lwe">Compliance with Nigerian and international standards</span>
            </li>
          </ul>
          <a href="/contact/" class="inline-block bg-[#E85D1A] text-slate-900 px-8 py-4 font-bold uppercase tracking-widest hover:bg-[#D04C0F] transition-colors" data-ps="src/pages/electrical-utilities-and-discos.astro:43n9y1">CONTACT US</a>
        </div>
        <div class="relative" data-ps="src/pages/electrical-utilities-and-discos.astro:vnoqpu">
          <img
            src="https://cdn.pagesmith.app/3ebbed7b/images/Elsan-Transformer-10-1024.webp"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Electrical Substation Transformer" 
            class="w-full h-auto shadow-2xl" data-ps="src/pages/electrical-utilities-and-discos.astro:1sfs2h" />
          <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-[#E85D1A]/10 -z-10" data-ps="src/pages/electrical-utilities-and-discos.astro:vnoqpv"></div>
        </div>
      </div>
    </div>
  </section>

  <Specifications />
  <Industries />
  <QuotationRequest />
</BaseLayout>
