---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import Specifications from '@/components/home/Specifications.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';
import Industries from '@/components/home/Industries.astro';
---

<BaseLayout
  title="Mining & Heavy Industry | Elsan Transformer"
  description="Robust transformers built for extreme conditions in mining and heavy industry operations."
>
  <PageHero 
    title="Mining & Heavy Industry" 
    subtitle="Rugged power solutions for the toughest environments, ensuring reliability underground and on the surface."
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/Elsan-Transformer-4-1024-1024.webp"
  />

  <section class="py-24 bg-white" data-ps="src/pages/mining-and-heavy-industry.astro:jwy90q">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/mining-and-heavy-industry.astro:7hxk73">
      <div class="grid md:grid-cols-2 gap-16 items-center" data-ps="src/pages/mining-and-heavy-industry.astro:7hxk74">
        <div data-ps="src/pages/mining-and-heavy-industry.astro:7hxk75">
          <h2 class="text-4xl font-black tracking-tighter text-slate-900 mb-6 uppercase" data-ps="src/pages/mining-and-heavy-industry.astro:sam1gk">Heavy Duty Performance</h2>
          <p class="text-lg text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/mining-and-heavy-industry.astro:d3lq4j">
            Robust units built for demanding duty cycles and extreme Nigerian environmental conditions, serving surface and underground mining operations across the region. Our mining transformers are designed to withstand dust, moisture, and mechanical stress.
          </p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3" data-ps="src/pages/mining-and-heavy-industry.astro:pili5i">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/mining-and-heavy-industry.astro:51l44g"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/mining-and-heavy-industry.astro:51l44f">High mechanical strength for vibration resistance</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/mining-and-heavy-industry.astro:pili5j">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/mining-and-heavy-industry.astro:51l44e"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/mining-and-heavy-industry.astro:51l44d">Compact designs for underground applications</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/mining-and-heavy-industry.astro:pili65">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/mining-and-heavy-industry.astro:51l44c"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/mining-and-heavy-industry.astro:51l44b">Enhanced cooling for high-load operations</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/mining-and-heavy-industry.astro:pili66">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/mining-and-heavy-industry.astro:51l44a"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/mining-and-heavy-industry.astro:903bqa">Protection against dust and humidity</span>
            </li>
          </ul>
          <a href="/contact/" class="inline-block bg-[#E85D1A] text-slate-900 px-8 py-4 font-bold uppercase tracking-widest hover:bg-[#D04C0F] transition-colors" data-ps="src/pages/mining-and-heavy-industry.astro:r6wqsn">CONTACT US</a>
        </div>
        <div class="relative" data-ps="src/pages/mining-and-heavy-industry.astro:7hxk76">
          <img
            src="https://cdn.pagesmith.app/3ebbed7b/images/Elsan-Transformer-4-1024.webp"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Mining Excavator" 
            class="w-full h-auto shadow-2xl" data-ps="src/pages/mining-and-heavy-industry.astro:mdbeg7" />
          <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-[#E85D1A]/10 -z-10" data-ps="src/pages/mining-and-heavy-industry.astro:7hxk77"></div>
        </div>
      </div>
    </div>
  </section>

  <Specifications />
  <Industries />
  <QuotationRequest />
</BaseLayout>
