---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';

const country = "Togo";
---

<BaseLayout
  title={`Transformer in ${country} | Elsan Transformers`}
  description={`Premier transformer solutions and power infrastructure for ${country}.`}
>
  <PageHero 
    title="Transformer in togo"
    subtitle={`Powering ${country}'s grid with high-efficiency distribution and power transformers.`}
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/IMG-20260226-WA0075-640-640.webp"
  />
  
  <section class="py-16 bg-white" data-ps="src/pages/transformer-in-togo.astro:section1">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/transformer-in-togo.astro:lpcdum">
      <div class="prose max-w-none prose-slate" data-ps="src/pages/transformer-in-togo.astro:lpcdul">
        <h2 class="text-3xl font-bold mb-6 text-slate-900" data-ps="src/pages/transformer-in-togo.astro:f979zd">Power Solutions for {country}</h2>
        
        <p class="text-lg text-slate-700 mb-8" data-ps="src/pages/transformer-in-togo.astro:9ss6w2">
          Elsan Transformer supplies certified power and distribution transformers to Togo, manufactured in Turkey to IEC 60076 and ISO 9001:2015 standards, with full export logistics from Nigeria to Lomé.
        </p>

        <h3 class="text-2xl font-semibold mt-10 mb-4 text-slate-900" data-ps="src/pages/transformer-in-togo.astro:w26cdh">Togo's Electricity Sector and Transformer Demand</h3>
        <p class="text-slate-700 mb-6" data-ps="src/pages/transformer-in-togo.astro:jntppg">
          Togo's national electricity distributor, CEET (Compagnie Energie Electrique du Togo), operates a medium and low voltage distribution network serving Lomé, Kara, Sokodé, and regional towns across the country's five regions. Grid expansion programmes, rising commercial energy demand in Lomé's business districts, and rural electrification projects funded by international development partners have created growing requirements for reliable, internationally certified transformer equipment suited to tropical West African operating conditions.
        </p>

        <h3 class="text-2xl font-semibold mt-10 mb-4 text-slate-900" data-ps="src/pages/transformer-in-togo.astro:w26cdi">Elsan's Transformer Range for Togo</h3>
        <p class="text-slate-700 mb-4" data-ps="src/pages/transformer-in-togo.astro:jntpph">Elsan Transformer supplies the complete range of units required across Togo's grid and project environments:</p>
        <ul class="list-disc pl-6 mb-8 text-slate-700 space-y-2">
          <li data-ps="src/pages/transformer-in-togo.astro:njjvwb"><strong>Distribution transformers:</strong> 25 kVA to 2,500 kVA — available for CEET's 15 kV and 33 kV networks in pole-mounted, pad-mounted, and compact substation configurations</li>
          <li data-ps="src/pages/transformer-in-togo.astro:njjvwa"><strong>Power transformers:</strong> 3.15 MVA to 50 MVA — for substation construction and major grid infrastructure works</li>
          <li data-ps="src/pages/transformer-in-togo.astro:njjvw9"><strong>Single-phase units:</strong> up to 160 kVA — suitable for rural electrification and last-mile connectivity programmes</li>
          <li data-ps="src/pages/transformer-in-togo.astro:njjvvn"><strong>Solar PV transformers:</strong> custom-engineered step-up units for Togo's expanding renewable energy sector</li>
        </ul>

        <p class="text-slate-700 mb-8" data-ps="src/pages/transformer-in-togo.astro:jntppi">
          All Elsan units deployed to Togo are oil-immersed with ONAN or ONAF cooling, precision-wound copper windings, and high-permeability grain-oriented silicon steel cores engineered to minimise no-load losses under continuous tropical operation. Factory routine testing to IEC 60076 is performed on every transformer before dispatch.
        </p>

        <h3 class="text-2xl font-semibold mt-10 mb-4 text-slate-900" data-ps="src/pages/transformer-in-togo.astro:es5mua">Standards, Certifications, and Documentation</h3>
        <p class="text-slate-700 mb-8" data-ps="src/pages/transformer-in-togo.astro:jntppj">
          Elsan transformers are manufactured to IEC 60076 and produced under ISO 9001:2015 quality management. The facility also holds ISO 14001 and ISO 45001 certification. Routine test certificates, type test reports, and full technical datasheets are provided as standard — meeting the documentation requirements for CEET approval and international development finance compliance.
        </p>

        <div class="mt-16 bg-slate-50 p-8 rounded-2xl border border-slate-200" data-ps="src/pages/transformer-in-togo.astro:lpcdup">
          <h2 class="text-3xl font-bold mb-8 text-slate-900" data-ps="src/pages/transformer-in-togo.astro:f979za">Frequently Asked Questions</h2>
          
          <div class="space-y-8" data-ps="src/pages/transformer-in-togo.astro:lpcduo">
            <div data-ps="src/pages/transformer-in-togo.astro:lpcdun">
              <h3 class="text-xl font-bold mb-3 text-slate-900" data-ps="src/pages/transformer-in-togo.astro:es5mub">Does Elsan export transformers to Togo?</h3>
              <p class="text-slate-700" data-ps="src/pages/transformer-in-togo.astro:jntppk">Yes. Elsan exports directly from Nigeria to Togo, with full export documentation and logistics coordination to Lomé.</p>
            </div>
            
            <div data-ps="src/pages/transformer-in-togo.astro:lpcdum">
              <h3 class="text-xl font-bold mb-3 text-slate-900" data-ps="src/pages/transformer-in-togo.astro:es5muc">What voltage classes are available for Togo?</h3>
              <p class="text-slate-700" data-ps="src/pages/transformer-in-togo.astro:jntppl">Units are available for 11 kV, 15 kV, 20 kV, and 33 kV primary voltage configurations.</p>
            </div>
            
            <div data-ps="src/pages/transformer-in-togo.astro:lpcdul">
              <h3 class="text-xl font-bold mb-3 text-slate-900" data-ps="src/pages/transformer-in-togo.astro:es5mud">Can Elsan manufacture to custom specifications?</h3>
              <p class="text-slate-700" data-ps="src/pages/transformer-in-togo.astro:jntppm">Yes — custom voltage ratios, tap configurations, and cooling classes are available on request.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <QuotationRequest />
</BaseLayout>
