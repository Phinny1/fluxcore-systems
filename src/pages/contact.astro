---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import Contact from '@/components/home/Contact.astro';
import FAQ from '@/components/home/FAQ.astro';
---

<BaseLayout
  title="Contact Us | Elsan Transformer"
  description="Get in touch with our team for inquiries, support, or quotations."
>
  <PageHero 
    title="Contact Us Today" 
    subtitle="We are here to assist you with all your power infrastructure needs."
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/IMG-20260226-WA0075-640-640.webp"
  />

  <div class="bg-slate-900 py-12" data-ps="src/pages/contact.astro:lx8n1m">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8 text-center" data-ps="src/pages/contact.astro:lx8n1l">
      <div class="p-8 bg-slate-800 rounded-xl border border-slate-700" data-ps="src/pages/contact.astro:lx8n1i">
        <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/contact.astro:rn54wt">Abuja – Utako Office</h3>
        <p class="text-slate-400" data-ps="src/pages/contact.astro:5muzal">Suite 17/18, Tian Plaza, Utako District, FCT, Abuja, Nigeria</p>
        <p class="text-slate-400" data-ps="src/pages/contact.astro:5muzak">Mon-Sat: 8am - 6pm</p>
      </div>
      <div class="p-8 bg-slate-800 rounded-xl border border-slate-700" data-ps="src/pages/contact.astro:lx8n1j">
        <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/contact.astro:rn54wu">Abuja – Gudu/Durumi Office</h3>
        <p class="text-slate-400" data-ps="src/pages/contact.astro:5muzai">Shop H1, Century Mall, Plot 162, David Ejor Street, Gudu–Durumi District, Abuja, Nigeria</p>
        <p class="text-slate-400" data-ps="src/pages/contact.astro:5muzak-2">Mon-Sat: 8am - 6pm</p>
      </div>
      <div class="p-8 bg-slate-800 rounded-xl border border-slate-700" data-ps="src/pages/contact.astro:lx8n1i-2">
        <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/contact.astro:rn54wv">Lagos – Ojo Office</h3>
        <p class="text-slate-400" data-ps="src/pages/contact.astro:5muzah">No. 10 Dauda Street, Ira Quarters, Volks, Ojo, Lagos, Nigeria</p>
        <p class="text-slate-400" data-ps="src/pages/contact.astro:5muzak-3">Mon-Sat: 8am - 6pm</p>
      </div>
    </div>
  </div>
  
  <Contact />

  <FAQ />
</BaseLayout>
