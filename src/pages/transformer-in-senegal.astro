---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';

const country = "Senegal";
---

<BaseLayout
  title={`Transformer in ${country} | Elsan Transformers`}
  description={`Premier transformer solutions and power infrastructure for ${country}.`}
>
  <PageHero 
    title={`Transformer in ${country}`}
    subtitle={`Powering ${country}'s grid with high-efficiency distribution and power transformers.`}
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/IMG-20260226-WA0075-640-640.webp"
  />
  
  <section class="py-16 bg-white" data-ps="src/pages/transformer-in-senegal.astro:section1">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/transformer-in-senegal.astro:uk2fpv">
      <div class="prose max-w-none" data-ps="src/pages/transformer-in-senegal.astro:uk2fpw">
        <h2 class="text-3xl font-bold mb-6 text-slate-900" data-ps="src/pages/transformer-in-senegal.astro:lioa2h">Power Solutions for {country}</h2>
        <p class="text-lg text-slate-700 mb-8 leading-relaxed" data-ps="src/pages/transformer-in-senegal.astro:8ensut">
          Elsan Transformer supplies certified power and distribution transformers to Senegal, manufactured in Turkey to IEC 60076 and ISO 9001:2015 standards, with full export documentation and logistics to Dakar port.
        </p>

        <h3 class="text-2xl font-bold mt-12 mb-6 text-slate-900" data-ps="src/pages/transformer-in-senegal.astro:d4h99o">Senegal's Electricity Sector and Transformer Requirements</h3>
        <p class="text-slate-700 mb-6 leading-relaxed" data-ps="src/pages/transformer-in-senegal.astro:8ensuu">
          Senegal's electricity network is managed by SENELEC (Société Nationale d'Electricité du Sénégal), serving Dakar, Thiès, Saint-Louis, Ziguinchor, and expanding grid corridors under the government's PUDC (Programme d'Urgence de Développement Communautaire) rural electrification initiative. Senegal's active offshore oil and gas sector (the Sangomar and Greater Tortue fields), rapid industrial expansion around the Dakar–Diamniadio corridor, and ambitious utility-scale solar targets — including projects at Tobène and Taïba Ndiaye — make Senegal one of West Africa's most dynamic transformer procurement markets.
        </p>

        <h3 class="text-2xl font-bold mt-12 mb-6 text-slate-900" data-ps="src/pages/transformer-in-senegal.astro:d4h99p">Elsan's Transformer Range for Senegal</h3>
        <p class="text-slate-700 mb-6 leading-relaxed" data-ps="src/pages/transformer-in-senegal.astro:8ensuv">
          Elsan supplies the full range of transformer types required across Senegal's utility, industrial, and renewable energy sectors:
        </p>
        <ul class="space-y-4 text-slate-700 mb-8">
          <li data-ps="src/pages/transformer-in-senegal.astro:sjv2yz"><strong>Distribution transformers:</strong> 25 kVA to 2,500 kVA — for SENELEC's 15 kV, 30 kV, and 33 kV medium-voltage networks, in pole-mounted and pad-mounted configurations</li>
          <li data-ps="src/pages/transformer-in-senegal.astro:sjv2z0"><strong>Power transformers:</strong> 3.15 MVA to 50 MVA — for substation, grid reinforcement, and large industrial connection projects</li>
          <li data-ps="src/pages/transformer-in-senegal.astro:sjv2z1"><strong>Single-phase units:</strong> up to 160 kVA — for PUDC rural electrification and last-mile connectivity</li>
          <li data-ps="src/pages/transformer-in-senegal.astro:sjv2z2"><strong>Solar PV transformers:</strong> custom step-up units engineered for Senegal's utility-scale solar park applications</li>
        </ul>
        <p class="text-slate-700 mb-6 leading-relaxed" data-ps="src/pages/transformer-in-senegal.astro:8ensvh">
          Elsan's oil-immersed units are sealed against Senegal's coastal humidity and salt air, with ONAN and ONAF cooling systems optimised for West African tropical ambient conditions. Precision copper windings and high-permeability grain-oriented steel cores ensure low no-load and load losses throughout the transformer's operational life. Full IEC 60076 factory testing is completed before dispatch.
        </p>

        <h3 class="text-2xl font-bold mt-12 mb-6 text-slate-900" data-ps="src/pages/transformer-in-senegal.astro:d4h99q">Standards, Certifications, and Documentation</h3>
        <p class="text-slate-700 mb-12 leading-relaxed" data-ps="src/pages/transformer-in-senegal.astro:8ensvi">
          Elsan's manufacturing facility holds ISO 9001:2015, ISO 14001, and ISO 45001 certification. All transformers comply with IEC 60076. Routine test certificates, type test reports, and full technical datasheets are provided — satisfying SENELEC procurement requirements and international development finance documentation standards.
        </p>

        <div class="bg-slate-50 p-8 rounded-2xl border border-slate-100" data-ps="src/pages/transformer-in-senegal.astro:uk2fpx">
          <h2 class="text-3xl font-bold mb-8 text-slate-900" data-ps="src/pages/transformer-in-senegal.astro:lioa2i">Frequently Asked Questions</h2>
          <div class="space-y-8" data-ps="src/pages/transformer-in-senegal.astro:uk2fpy">
            <div data-ps="src/pages/transformer-in-senegal.astro:uk2fpz">
              <h3 class="text-xl font-bold mb-3 text-slate-900" data-ps="src/pages/transformer-in-senegal.astro:d4h99r">Does Elsan deliver to Senegal?</h3>
              <p class="text-slate-700" data-ps="src/pages/transformer-in-senegal.astro:8ensvj">Yes — full export from Nigeria to Dakar with complete shipping documentation.</p>
            </div>
            <div data-ps="src/pages/transformer-in-senegal.astro:uk2fq0">
              <h3 class="text-xl font-bold mb-3 text-slate-900" data-ps="src/pages/transformer-in-senegal.astro:d4h99s">Are solar PV step-up transformers available?</h3>
              <p class="text-slate-700" data-ps="src/pages/transformer-in-senegal.astro:8ensvk">Yes — custom-engineered solar transformers are a dedicated product line.</p>
            </div>
            <div data-ps="src/pages/transformer-in-senegal.astro:uk2fq1">
              <h3 class="text-xl font-bold mb-3 text-slate-900" data-ps="src/pages/transformer-in-senegal.astro:l1mmxk">What voltage classes are stocked?</h3>
              <p class="text-slate-700" data-ps="src/pages/transformer-in-senegal.astro:8ensvl">11 kV, 15 kV, 20 kV, 30 kV, and 33 kV primary configurations.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <QuotationRequest />
</BaseLayout>
