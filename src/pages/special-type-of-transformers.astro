---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import Specifications from '@/components/home/Specifications.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';
import Industries from '@/components/home/Industries.astro';
---

<BaseLayout
  title="Special Type Transformers | Elsan Transformer"
  description="Custom-engineered transformers for specialized industrial processes, furnace applications, and rectification."
>
  <PageHero 
    title="Special Type Transformers" 
    subtitle="Bespoke engineering solutions for unique industrial and technical requirements."
    backgroundImage="https://images.unsplash.com/photo-1518314916381-77a37c2a49ae?auto=format&w=1200&q=80"
  />

  <section class="py-24 bg-white" data-ps="src/pages/special-type-of-transformers.astro:1">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/special-type-of-transformers.astro:3eenzb">
      <div class="grid md:grid-cols-2 gap-16 items-center" data-ps="src/pages/special-type-of-transformers.astro:3eenza">
        <div class="order-2 md:order-1 relative" data-ps="src/pages/special-type-of-transformers.astro:3eenz9">
          <img
            src="https://cdn.pagesmith.app/3ebbed7b/images/Elsan-Transformer-9-1024.webp" 
            alt="Custom Industrial Transformer" 
            class="w-full h-auto shadow-2xl" data-ps="src/pages/special-type-of-transformers.astro:x9nmmk" />
          <div class="absolute -top-6 -left-6 w-48 h-48 bg-[#E85D1A]/10 -z-10" data-ps="src/pages/special-type-of-transformers.astro:3eenz8"></div>
        </div>
        <div class="order-1 md:order-2" data-ps="src/pages/special-type-of-transformers.astro:3eenz7">
          <h2 class="text-4xl font-black tracking-tighter text-slate-900 mb-6 uppercase" data-ps="src/pages/special-type-of-transformers.astro:wkj9xb">Custom Engineering</h2>
          <p class="text-lg text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/special-type-of-transformers.astro:f5y4tk">
            When standard units won't suffice, our engineering team designs custom transformers for specialized applications. From furnace transformers to rectifier units, we build to your exact performance parameters.
          </p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3" data-ps="src/pages/special-type-of-transformers.astro:fzzolp">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/special-type-of-transformers.astro:59ym13"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/special-type-of-transformers.astro:59ym14">Furnace and Rectifier Transformers</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/special-type-of-transformers.astro:fzzomb">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/special-type-of-transformers.astro:59ym15"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/special-type-of-transformers.astro:59ym16">Dual-voltage and Phase-shifting units</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/special-type-of-transformers.astro:fzzomc">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/special-type-of-transformers.astro:59ym17"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/special-type-of-transformers.astro:59ym18">Harmonic-resistant designs</span>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/special-type-of-transformers.astro:fzzomd">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0" data-ps="src/pages/special-type-of-transformers.astro:mqqwg4"></span>
              <span class="text-slate-700 font-medium" data-ps="src/pages/special-type-of-transformers.astro:mqqwg3">Tailored dimensions for restricted spaces</span>
            </li>
          </ul>
          <a href="/contact/" class="inline-block bg-[#E85D1A] text-slate-900 px-8 py-4 font-bold uppercase tracking-widest hover:bg-[#D04C0F] transition-colors" data-ps="src/pages/special-type-of-transformers.astro:y7c572">CONTACT US</a>
        </div>
      </div>
    </div>
  </section>

  <Specifications />
  <Industries />
  <QuotationRequest />
</BaseLayout>
