---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';

const country = "Niger";
---

<BaseLayout
  title={`Transformer in ${country} | Elsan Transformers`}
  description={`Premier transformer solutions and power infrastructure for ${country}.`}
>
  <PageHero 
    title={`Transformer in ${country}`}
    subtitle={`Powering ${country}'s grid with high-efficiency distribution and power transformers.`}
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/IMG-20260226-WA0075-640-640.webp"
  />
  
  <section class="py-16 bg-white" data-ps="src/pages/transformer-in-niger.astro:section1">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/transformer-in-niger.astro:hdtzpu">
      <div class="prose prose-slate max-w-none" data-ps="src/pages/transformer-in-niger.astro:hdtzpt">
        <p class="text-lg leading-relaxed mb-8" data-ps="src/pages/transformer-in-niger.astro:fcuqv2">
          Elsan Transformer supplies certified power and distribution transformers to Niger, manufactured in Turkey to IEC 60076 and ISO 9001:2015 standards, with export from Nigeria to Niamey and regional destinations.
        </p>

        <h2 class="text-3xl font-bold mb-6" data-ps="src/pages/transformer-in-niger.astro:oi6yln">Niger's Electricity Sector and Transformer Requirements</h2>
        <p class="mb-6" data-ps="src/pages/transformer-in-niger.astro:fcuqv3">
          Niger's national electricity utility, NIGELEC (Société Nigérienne d'Electricité), operates a distribution network centred on Niamey and extending to Dosso, Tahoua, Maradi, Agadez, and Zinder. With only a fraction of Niger's population connected to grid electricity, major national and internationally financed electrification programmes are actively underway — creating significant demand for transformers that can perform reliably in one of the world's most extreme operating environments, where ambient temperatures regularly exceed 45°C across the Sahel and Sahara zones.
        </p>

        <h2 class="text-3xl font-bold mb-6" data-ps="src/pages/transformer-in-niger.astro:nvbdre">Elsan's Transformer Range for Niger</h2>
        <p class="mb-4" data-ps="src/pages/transformer-in-niger.astro:fcuqv4">Elsan supplies transformer equipment suited to Niger's harsh climate and grid development priorities:</p>
        <ul class="list-disc pl-6 mb-8 space-y-2">
          <li data-ps="src/pages/transformer-in-niger.astro:uen7fj"><strong>Distribution transformers:</strong> 25 kVA to 2,500 kVA — for NIGELEC's medium-voltage network at 15 kV and 33 kV, in configurations suited to desert and Sahelian environments</li>
          <li data-ps="src/pages/transformer-in-niger.astro:uen7fk"><strong>Power transformers:</strong> 3.15 MVA to 50 MVA — for substation construction and grid reinforcement under Niger's national development plans</li>
          <li data-ps="src/pages/transformer-in-niger.astro:uen7fl"><strong>Single-phase units:</strong> up to 160 kVA — for rural electrification and last-mile access programmes across Niger's dispersed communities</li>
          <li data-ps="src/pages/transformer-in-niger.astro:uen7g7"><strong>Solar PV transformers:</strong> engineered for off-grid solar installations across Niger's vast, underserved rural regions</li>
        </ul>

        <p class="mb-8" data-ps="src/pages/transformer-in-niger.astro:fcuqv5">
          Elsan transformers for Niger are specified with thermal-stability-rated transformer oil, optimised cooling fin geometry for maximum heat dissipation, and insulation systems rated for continuous operation at elevated ambient temperatures. Factory routine testing to IEC 60076 is conducted on every unit before dispatch, confirming performance under the thermal and electrical demands of Niger's grid.
        </p>

        <h2 class="text-3xl font-bold mb-6" data-ps="src/pages/transformer-in-niger.astro:nvbdrf">Standards, Certifications, and Documentation</h2>
        <p class="mb-8" data-ps="src/pages/transformer-in-niger.astro:fcuqv6">
          Elsan holds ISO 9001:2015, ISO 14001, and ISO 45001 certifications. Full IEC 60076 compliance is standard on all products. Routine test certificates, type test reports, and technical datasheets are provided as standard — satisfying the documentation requirements of NIGELEC procurement and World Bank, AfDB, or bilateral-financed project compliance.
        </p>

        <div class="bg-slate-50 p-8 rounded-2xl border border-slate-100 mt-12" data-ps="src/pages/transformer-in-niger.astro:h167wl">
          <h2 class="text-3xl font-bold mb-8" data-ps="src/pages/transformer-in-niger.astro:nvbdrg">Frequently Asked Questions</h2>
          
          <div class="space-y-8" data-ps="src/pages/transformer-in-niger.astro:h167wm">
            <div data-ps="src/pages/transformer-in-niger.astro:h167wn">
              <h3 class="text-xl font-bold text-slate-900 mb-2" data-ps="src/pages/transformer-in-niger.astro:ez9dq8">Does Elsan export to Niger?</h3>
              <p class="text-slate-600" data-ps="src/pages/transformer-in-niger.astro:fcuqv7">Yes. Elsan exports from Nigeria to Niamey and other Niger destinations with full documentation.</p>
            </div>
            
            <div data-ps="src/pages/transformer-in-niger.astro:h167wo">
              <h3 class="text-xl font-bold text-slate-900 mb-2" data-ps="src/pages/transformer-in-niger.astro:ne9qmg">Are transformers rated for 45°C+ ambient temperatures?</h3>
              <p class="text-slate-600" data-ps="src/pages/transformer-in-niger.astro:fcuqv8">Yes — units are engineered for extreme Sahelian heat as standard.</p>
            </div>
            
            <div data-ps="src/pages/transformer-in-niger.astro:h167wp">
              <h3 class="text-xl font-bold text-slate-900 mb-2" data-ps="src/pages/transformer-in-niger.astro:ne9qmh">What documentation is provided?</h3>
              <p class="text-slate-600" data-ps="src/pages/transformer-in-niger.astro:fcuqv9">IEC 60076 test certificates, ISO 9001 quality records, and full technical datasheets.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <QuotationRequest />
</BaseLayout>
