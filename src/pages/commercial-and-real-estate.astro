---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import Specifications from '@/components/home/Specifications.astro';
import QuotationRequest from '@/components/home/QuotationRequest.astro';
import Industries from '@/components/home/Industries.astro';
---

<BaseLayout
  title="Commercial & Real Estate | Elsan Transformer"
  description="Efficient transformers for commercial developments, shopping centers, and office towers."
>
  <PageHero
    title="Commercial & Real Estate"
    subtitle="Powering modern spaces with quiet, efficient, and reliable transformer solutions."
    backgroundImage="https://cdn.pagesmith.app/3ebbed7b/images/Elsan-Transformer-2-1024-1024-1024.webp"
  />

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-4xl font-black tracking-tighter text-slate-900 mb-6 uppercase">Powering Urban Spaces</h2>
          <p class="text-lg text-slate-600 mb-8 leading-relaxed">
            Distribution transformers for commercial developments, shopping centres, hospitals, office towers, and data centres across Nigeria's major cities. Our units are designed to be unobtrusive, safe, and highly efficient for urban environments.
          </p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0"></span>
              <span class="text-slate-700 font-medium">Low noise levels for urban areas</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0"></span>
              <span class="text-slate-700 font-medium">Compact footprints for space-constrained sites</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0"></span>
              <span class="text-slate-700 font-medium">Aesthetically pleasing enclosure options</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-[#E85D1A] shrink-0"></span>
              <span class="text-slate-700 font-medium">Safe for public-adjacent installations</span>
            </li>
          </ul>
          <a href="/contact/" class="inline-block bg-[#E85D1A] text-slate-900 px-8 py-4 font-bold uppercase tracking-widest hover:bg-[#D04C0F] transition-colors">CONTACT US</a>
        </div>
        <div class="relative">
          <img
            src="https://cdn.pagesmith.app/3ebbed7b/images/Elsan-Transformer-2-1024-1024-1024.webp"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Commercial Building"
            loading="lazy"
            class="w-full h-auto shadow-2xl" />
          <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-[#E85D1A]/10 -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <Specifications />
  <Industries />
  <QuotationRequest />
</BaseLayout>
