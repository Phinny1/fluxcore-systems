---
---

<section id="contact" class="py-20 bg-slate-50 relative overflow-hidden" data-ps="src/components/home/QuotationRequest.astro:m446br">
  <div class="container mx-auto px-4 relative z-10" data-ps="src/components/home/QuotationRequest.astro:jqwtoy">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start" data-ps="src/components/home/QuotationRequest.astro:jqwtoz">
      
      <!-- LEFT COLUMN -->
      <div data-ps="src/components/home/QuotationRequest.astro:jqwtp0">
        <span class="text-sm font-bold tracking-widest text-[var(--primary)] uppercase mb-3 block" data-ps="src/components/home/QuotationRequest.astro:mv5g1a">GET IN TOUCH</span>
        <h2 class="text-4xl md:text-5xl font-extrabold mb-6 text-slate-900 leading-tight" data-ps="src/components/home/QuotationRequest.astro:uqoly0">
          Request an <span class="text-[var(--primary)]" data-ps="src/components/home/QuotationRequest.astro:mv5g1w">Engineering Quotation</span>
        </h2>
        <p class="text-slate-600 text-lg leading-relaxed mb-10" data-ps="src/components/home/QuotationRequest.astro:8759ik">
          Whether you need a standard distribution transformer, a custom-engineered power transformer, or technical advice on your project, the Elsan Transformer team is ready to help. Our engineers respond within one business day with pricing, availability, and technical recommendations.
        </p>

        <div class="space-y-6" data-ps="src/components/home/QuotationRequest.astro:jqwtpm">
          <!-- Phone -->
          <div class="flex items-start border-b border-slate-200 pb-6" data-ps="src/components/home/QuotationRequest.astro:jqwtpn">
            <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center mr-5 shrink-0 text-slate-600" data-ps="src/components/home/QuotationRequest.astro:jqwtpo">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div data-ps="src/components/home/QuotationRequest.astro:jqwtpp">
              <p class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-1" data-ps="src/components/home/QuotationRequest.astro:8759il">Phone</p>
              <p class="text-lg font-medium text-slate-900" data-ps="src/components/home/QuotationRequest.astro:8759im">+2348033142634</p>
            </div>
          </div>

          <!-- Whatsapp -->
          <div class="flex items-start border-b border-slate-200 pb-6" data-ps="src/components/home/QuotationRequest.astro:jqwtpq">
            <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center mr-5 shrink-0 text-slate-600" data-ps="src/components/home/QuotationRequest.astro:jqwtpr">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
            </div>
            <div data-ps="src/components/home/QuotationRequest.astro:jqwtps">
              <p class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-1" data-ps="src/components/home/QuotationRequest.astro:8759in">Whatsapp</p>
              <p class="text-lg font-medium text-[var(--primary)]" data-ps="src/components/home/QuotationRequest.astro:8759io">+2348033142634</p>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start border-b border-slate-200 pb-6" data-ps="src/components/home/QuotationRequest.astro:jqwtpt">
            <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center mr-5 shrink-0 text-slate-600" data-ps="src/components/home/QuotationRequest.astro:jqwtpu">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div data-ps="src/components/home/QuotationRequest.astro:jqwtpv">
              <p class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-1" data-ps="src/components/home/QuotationRequest.astro:8759ip">Email</p>
              <p class="text-lg font-medium text-[var(--primary)]" data-ps="src/components/home/QuotationRequest.astro:8759iq">[email protected]</p>
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-start border-b border-slate-200 pb-6" data-ps="src/components/home/QuotationRequest.astro:jqwtqh">
            <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center mr-5 shrink-0 text-slate-600" data-ps="src/components/home/QuotationRequest.astro:jqwtqi">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div data-ps="src/components/home/QuotationRequest.astro:jqwtqj">
              <p class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-1" data-ps="src/components/home/QuotationRequest.astro:8759ir">Offices</p>
              <div class="space-y-1" data-ps="src/components/home/QuotationRequest.astro:8j0mip">
                <p class="text-sm font-medium text-slate-900" data-ps="src/components/home/QuotationRequest.astro:8759jd">Abuja: Utako & Gudu/Durumi Districts</p>
                <p class="text-sm font-medium text-slate-900" data-ps="src/components/home/QuotationRequest.astro:u1uwhs">Lagos: Ojo Office</p>
              </div>
            </div>
          </div>

          <!-- Business Hours -->
          <div class="flex items-start" data-ps="src/components/home/QuotationRequest.astro:jqwtqk">
            <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center mr-5 shrink-0 text-slate-600" data-ps="src/components/home/QuotationRequest.astro:jqwtql">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div data-ps="src/components/home/QuotationRequest.astro:jqwtqm">
              <p class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-1" data-ps="src/components/home/QuotationRequest.astro:8759je">Business Hours</p>
              <p class="text-lg font-medium text-slate-900" data-ps="src/components/home/QuotationRequest.astro:8759jf">Monday – Saturday, 08:00 – 18:00</p>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN - Form Card -->
      <div class="bg-white p-8 md:p-10 rounded-2xl shadow-xl border border-slate-100" data-ps="src/components/home/QuotationRequest.astro:jqwtqn">
        <h3 class="text-2xl font-bold text-slate-900 mb-2" data-ps="src/components/home/QuotationRequest.astro:pm0itj">Engineering Quotation Request</h3>
        <p class="text-slate-500 mb-8 text-sm" data-ps="src/components/home/QuotationRequest.astro:8759jg">Complete the form and our technical sales team will contact you within one business day with pricing, availability, and technical recommendations.</p>
        
        <form class="space-y-6">
          <!-- Row 1 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-ps="src/components/home/QuotationRequest.astro:jqwtqo">
            <div data-ps="src/components/home/QuotationRequest.astro:jqwtqp">
              <label class="block text-xs font-bold uppercase text-slate-500 mb-2" for="first-name">First Name</label>
              <input type="text" id="first-name" placeholder="John" class="w-full bg-slate-50 border border-slate-200 rounded px-4 py-3 text-slate-900 focus:outline-none focus:border-[var(--primary)] focus:ring-1 focus:ring-[var(--primary)] transition-colors placeholder:text-slate-400" />
            </div>
            <div data-ps="src/components/home/QuotationRequest.astro:jqwtqq">
              <label class="block text-xs font-bold uppercase text-slate-500 mb-2" for="last-name">Last Name</label>
              <input type="text" id="last-name" placeholder="Smith" class="w-full bg-slate-50 border border-slate-200 rounded px-4 py-3 text-slate-900 focus:outline-none focus:border-[var(--primary)] focus:ring-1 focus:ring-[var(--primary)] transition-colors placeholder:text-slate-400" />
            </div>
          </div>

          <!-- Row 2 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-ps="src/components/home/QuotationRequest.astro:8j0miy">
            <div data-ps="src/components/home/QuotationRequest.astro:8j0mix">
              <label class="block text-xs font-bold uppercase text-slate-500 mb-2" for="company">Company / Organisation</label>
              <input type="text" id="company" placeholder="Acme Power Ltd." class="w-full bg-slate-50 border border-slate-200 rounded px-4 py-3 text-slate-900 focus:outline-none focus:border-[var(--primary)] focus:ring-1 focus:ring-[var(--primary)] transition-colors placeholder:text-slate-400" />
            </div>
            <div data-ps="src/components/home/QuotationRequest.astro:8j0miw">
              <label class="block text-xs font-bold uppercase text-slate-500 mb-2" for="email">Email Address</label>
              <input type="email" id="email" placeholder="john@company.com" class="w-full bg-slate-50 border border-slate-200 rounded px-4 py-3 text-slate-900 focus:outline-none focus:border-[var(--primary)] focus:ring-1 focus:ring-[var(--primary)] transition-colors placeholder:text-slate-400" />
            </div>
          </div>

          <!-- Row 3 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-ps="src/components/home/QuotationRequest.astro:8j0miv">
            <div data-ps="src/components/home/QuotationRequest.astro:8j0miu">
              <label class="block text-xs font-bold uppercase text-slate-500 mb-2" for="phone">Phone / WhatsApp</label>
              <input type="tel" id="phone" placeholder="+234 803 314 2634" class="w-full bg-slate-50 border border-slate-200 rounded px-4 py-3 text-slate-900 focus:outline-none focus:border-[var(--primary)] focus:ring-1 focus:ring-[var(--primary)] transition-colors placeholder:text-slate-400" />
            </div>
            <div data-ps="src/components/home/QuotationRequest.astro:8j0mit">
              <label class="block text-xs font-bold uppercase text-slate-500 mb-2" for="country">Country</label>
              <input type="text" id="country" placeholder="Nigeria" class="w-full bg-slate-50 border border-slate-200 rounded px-4 py-3 text-slate-900 focus:outline-none focus:border-[var(--primary)] focus:ring-1 focus:ring-[var(--primary)] transition-colors placeholder:text-slate-400" />
            </div>
          </div>

          <!-- Row 4 -->
          <div data-ps="src/components/home/QuotationRequest.astro:8j0mis">
            <label class="block text-xs font-bold uppercase text-slate-500 mb-2" for="product-type">Product Type Required</label>
            <div class="relative" data-ps="src/components/home/QuotationRequest.astro:8j0mir">
              <select id="product-type" class="w-full bg-slate-50 border border-slate-200 rounded px-4 py-3 text-slate-900 focus:outline-none focus:border-[var(--primary)] focus:ring-1 focus:ring-[var(--primary)] transition-colors appearance-none cursor-pointer">
                <option value="" disabled selected>Select product type...</option>
                <option value="Distribution Transformer">Distribution Transformer (25 kVA – 2,500 kVA)</option>
                <option value="Power Transformer">Power Transformer (3.15 MVA – 40 MVA)</option>
                <option value="Single Phase Transformer">Single Phase Transformer (up to 160 kVA)</option>
                <option value="Special Type">Special Type / Solar Transformer</option>
                <option value="Multiple Units">Both / Multiple Units</option>
                <option value="Custom">Custom / Non-Standard Specification</option>
              </select>
              <div class="absolute inset-y-0 right-0 flex items-center px-4 pointer-events-none text-slate-500" data-ps="src/components/home/QuotationRequest.astro:8j0miq">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </div>
          </div>

          <!-- Row 5 -->
          <div data-ps="src/components/home/QuotationRequest.astro:8j0mip">
            <label class="block text-xs font-bold uppercase text-slate-500 mb-2" for="details">Technical Requirements & Project Details</label>
            <textarea id="details" rows="4" placeholder="Please describe your voltage class (11kV / 33kV / 132kV), kVA/MVA rating, quantity, delivery location in Nigeria or West Africa, and any special requirements..." class="w-full bg-slate-50 border border-slate-200 rounded px-4 py-3 text-slate-900 focus:outline-none focus:border-[var(--primary)] focus:ring-1 focus:ring-[var(--primary)] transition-colors placeholder:text-slate-400 resize-y"></textarea>
          </div>

          <!-- Submit Button -->
          <button type="submit" class="w-full bg-[var(--primary)] hover:bg-[#D04C0F] text-white font-bold py-4 px-6 rounded uppercase tracking-wider transition-colors flex items-center justify-center gap-2 group" data-ps="src/components/home/QuotationRequest.astro:p20r0z">
            Submit Quotation Request 
            <span class="group-hover:translate-x-1 transition-transform" data-ps="src/components/home/QuotationRequest.astro:mv5g1x">→</span>
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
