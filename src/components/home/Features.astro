  <div class="max-w-7xl mx-auto px-6" data-ps="src/components/home/Features.astro:e0j4yn">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12" data-ps="src/components/home/Features.astro:e0j4ym">
