        <div class="w-14 h-14 bg-slate-50 flex items-center justify-center mb-8 border border-slate-100 group-hover:border-[#E85D1A] transition-colors" data-ps="src/components/home/Features.astro:e0j4yl">
          <svg class="w-8 h-8 text-[#E85D1A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
