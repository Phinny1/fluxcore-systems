<section id="industries" class="py-20 bg-[var(--surface)]" data-ps="src/components/home/Industries.astro:vnnhzq">
  <div class="container mx-auto px-4" data-ps="src/components/home/Industries.astro:q52bnn">
    <div class="max-w-3xl mb-16" data-ps="src/components/home/Industries.astro:q52bno">
      <span class="text-sm font-bold tracking-widest text-[var(--primary)] uppercase mb-3 block" data-ps="src/components/home/Industries.astro:d0vy5g">SECTORS WE SERVE</span>
