<script>
  function initTabs() {
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-target');

        // Update Buttons
        tabBtns.forEach(b => {
          b.classList.remove('border-[#E85D1A]', 'text-[#E85D1A]');
          b.classList.add('border-transparent', 'text-gray-600');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('border-[#E85D1A]', 'text-[#E85D1A]');
        btn.classList.remove('border-transparent', 'text-gray-500');
        btn.setAttribute('aria-selected', 'true');

        // Update Panels
        tabPanels.forEach(p => {
          p.classList.add('hidden');
          p.classList.remove('active');
        });
        const activePanel = document.getElementById(target);
        if (activePanel) {
          activePanel.classList.remove('hidden');
          setTimeout(() => activePanel.classList.add('active'), 50);
        }
      });
    });
  }

  // Run on load
  initTabs();
  // Run on view transition (if using Astro View Transitions)
  document.addEventListener('astro:after-swap', initTabs);
</script>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .tab-panel {
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease-out;
  }
  .tab-panel.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>
