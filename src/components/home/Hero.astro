---
// Hero component for FluxCore Systems
import { SITE } from '@/config/site';
---

<section id="hero" class="relative min-h-screen flex items-center bg-slate-950 overflow-hidden" data-ps="src/components/home/Hero.astro:flux-hero">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0" data-ps="src/components/home/Hero.astro:ecxgf9">
    <img
      src="https://cdn.pagesmith.app/3ebbed7b/images/Elsan-Transformer-2-1024-1024.webp"
      alt="Elsan high-efficiency power and distribution transformer"
      class="w-full h-full object-cover opacity-40"
      loading="eager"
      fetchpriority="high" data-ps="src/components/home/Hero.astro:fibi80" />
    <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-950/80 to-transparent" data-ps="src/components/home/Hero.astro:ecxgfa"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 py-10 w-full" data-ps="src/components/home/Hero.astro:hero-content">
    <div class="max-w-3xl" data-ps="src/components/home/Hero.astro:ecxgfb">
      <div class="hero-animate inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#E85D1A]/10 border border-[#E85D1A]/20 mb-6" data-ps="src/components/home/Hero.astro:ecxgfc">
        <span class="relative flex h-2 w-2" data-ps="src/components/home/Hero.astro:3f6ipl">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#E85D1A] opacity-75" data-ps="src/components/home/Hero.astro:3f6ipk"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[#E85D1A]" data-ps="src/components/home/Hero.astro:3f6ipj"></span>
        </span>
        <span class="text-xs font-bold uppercase tracking-widest text-[#E85D1A]" data-ps="src/components/home/Hero.astro:3f6ipi">High Efficiency &  Performance</span>
      </div>
      
      <h1 class="hero-animate hero-animate-delay-1 text-5xl md:text-7xl font-black text-white leading-tight mb-8 tracking-tighter" data-ps="src/components/home/Hero.astro:h1">Power & Distribution Transformers</h1>
      
      <p class="hero-animate hero-animate-delay-2 text-xl md:text-2xl text-slate-300 mb-10 leading-relaxed max-w-2xl" data-ps="src/components/home/Hero.astro:p">Elsan Transformer is a specialist manufacturer of high-efficiency power and distribution transformers — engineered for tropical grid conditions and supplied to utilities, DISCOs, and industrial projects across Nigeria and West Africa. Manufactured in Turkey to IEC 60076 and ISO 9001:2015 standards since 2018.</p>
      
      <div class="hero-animate hero-animate-delay-3 flex flex-wrap gap-4" data-ps="src/components/home/Hero.astro:actions">
        <a href="#products" class="px-8 py-4 bg-[#E85D1A] text-white font-bold uppercase tracking-widest hover:bg-[#D04C0F] transition-all hover:-translate-y-1 shadow-lg shadow-orange-900/20 active:translate-y-0" data-ps="src/components/home/Hero.astro:8zc2w">
          View Catalog
        </a>
        <a href="#contact" class="px-8 py-4 border border-slate-700 text-white font-bold uppercase tracking-widest hover:bg-white hover:text-slate-950 transition-all hover:-translate-y-1 active:translate-y-0" data-ps="src/components/home/Hero.astro:8zc2x">
          Request Specs
        </a>
      </div>
    </div>
  </div>
</section>
