<!-- Google Translate Widget (Hidden) -->
<!-- Google Translate Widget (Must be present but can be hidden) -->
<div id="google_translate_element" aria-hidden="true" data-ps="src/components/Navigation.astro:gqvsde"></div>

<style is:global>
  /* 
     AGGRESSIVE GOOGLE TRANSLATE UI REMOVAL
     Ensures no popups, banners, or layout shifts appear when translating
  */
  
  /* Hide the top banner frame */
  .goog-te-banner-frame, 
  .goog-te-banner-frame.skiptranslate,
  iframe.goog-te-banner-frame,
  #goog-gt-tt,
  .goog-te-balloon-frame {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    height: 0 !important;
    width: 0 !important;
  }

  /* Force body to stay at top and ignore Google's injected 40px margin */
  body {
    top: 0 !important;
    position: static !important;
  }

  /* Hide the gadget/widget entirely */
  .goog-te-gadget,
  .goog-te-gadget-simple,
  .goog-te-gadget-icon,
  .goog-te-menu-value,
  #google_translate_element {
    display: none !important;
    visibility: hidden !important;
  }

  /* Remove highlight on hover/translation */
  .goog-text-highlight {
    background-color: transparent !important;
    border: none !important; 
    box-shadow: none !important;
  }

  /* Prevent Google from adding 'translated' class styles to body */
  .translated-ltr, .translated-rtl {
    margin-top: 0 !important;
  }

  /* Ensure our navigation stays on top and isn't pushed down */
  #navbar {
    top: 0 !important;
  }

  /* Hide tooltips and progress indicators */
  .goog-tooltip, 
  .goog-tooltip:hover,
  .skiptranslate > iframe {
    display: none !important;
    visibility: hidden !important;
  }
</style>

<script is:inline>
  function googleTranslateElementInit() {
    new google.translate.TranslateElement({
      pageLanguage: 'en',
      includedLanguages: 'en,fr',
      layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
      autoDisplay: false,
    }, 'google_translate_element');
  }

  function switchLanguage(lang) {
    // Force aggressive cookie setting for Google Translate
    const cookieName = 'googtrans';
    const domain = window.location.hostname;
    const cookieValue = lang === 'fr' ? '/en/fr' : '/en/en';
    
    // 1. Clear existing cookies (expires in past)
    document.cookie = cookieName + "=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
    document.cookie = cookieName + "=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=" + domain;
    document.cookie = cookieName + "=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=." + domain;

    // 2. Set new cookie (if not clearing for default)
    // We set it on multiple paths/domains to ensure Google picks it up
    const date = new Date();
    date.setTime(date.getTime() + (30 * 24 * 60 * 60 * 1000)); // 30 days
    const expires = "; expires=" + date.toUTCString();
    
    // Set for root path
    document.cookie = cookieName + "=" + cookieValue + expires + "; path=/";
    document.cookie = cookieName + "=" + cookieValue + expires + "; path=/; domain=" + domain;
    
    // 3. Reload to apply
    window.location.reload();
  }
  
  // Make globally available
  window.googleTranslateElementInit = googleTranslateElementInit;
  window.switchLanguage = switchLanguage;
</script>
