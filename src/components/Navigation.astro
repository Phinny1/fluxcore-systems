<script is:inline>
  const navbar = document.getElementById('navbar');
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');

  function updateNavbar() {
    if (window.scrollY > 50) {
      navbar?.classList.add('md:bg-slate-950/90');
    } else {
      navbar?.classList.remove('md:bg-slate-950/90');
    }
  }
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  function toggleMenu(manual = true) {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      menuIconOpen?.classList.remove('hidden');
      menuIconClose?.classList.add('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      
      // If closing manually (click/esc), and we added a state, go back
      if (manual && window.history.state === 'menu-open') {
        window.history.back();
      }
    } else {
      mobileMenu?.classList.remove('hidden');
      menuIconOpen?.classList.add('hidden');
      menuIconClose?.classList.remove('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      
      // Push state so back button closes menu
      window.history.pushState('menu-open', '');
    }
  }

  mobileMenuButton?.addEventListener('click', () => toggleMenu(true));

  // Close menu on back button
  window.addEventListener('popstate', (event) => {
    if (!mobileMenu?.classList.contains('hidden')) {
      toggleMenu(false);
    }
  });

  const mobileProductsButton = document.getElementById('mobile-products-button');
  const mobileProductsMenu = document.getElementById('mobile-products-menu');
  const mobileProductsIcon = document.getElementById('mob-products-icon');

  mobileProductsButton?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = mobileProductsMenu?.classList.contains('hidden');
    if (isHidden) {
      mobileProductsMenu?.classList.remove('hidden');
      mobileProductsIcon?.classList.add('rotate-180');
      // Close other menu
      mobileServicesMenu?.classList.add('hidden');
      mobileServicesIcon?.classList.remove('rotate-180');
    } else {
      mobileProductsMenu?.classList.add('hidden');
      mobileProductsIcon?.classList.remove('rotate-180');
    }
  });

  const mobileServicesButton = document.getElementById('mobile-services-button');
  const mobileServicesMenu = document.getElementById('mobile-services-menu');
  const mobileServicesIcon = document.getElementById('mob-services-icon');

  mobileServicesButton?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = mobileServicesMenu?.classList.contains('hidden');
    if (isHidden) {
      mobileServicesMenu?.classList.remove('hidden');
      mobileServicesIcon?.classList.add('rotate-180');
      // Close other menus
      mobileProductsMenu?.classList.add('hidden');
      mobileProductsIcon?.classList.remove('rotate-180');
      mobileIndustryMenu?.classList.add('hidden');
      mobileIndustryIcon?.classList.remove('rotate-180');
    } else {
      mobileServicesMenu?.classList.add('hidden');
      mobileServicesIcon?.classList.remove('rotate-180');
    }
  });

  const mobileIndustryButton = document.getElementById('mobile-industry-button');
  const mobileIndustryMenu = document.getElementById('mobile-industry-menu');
  const mobileIndustryIcon = document.getElementById('mob-industry-icon');

  mobileIndustryButton?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = mobileIndustryMenu?.classList.contains('hidden');
    if (isHidden) {
      mobileIndustryMenu?.classList.remove('hidden');
      mobileIndustryIcon?.classList.add('rotate-180');
      // Close other menus
      mobileProductsMenu?.classList.add('hidden');
      mobileProductsIcon?.classList.remove('rotate-180');
      mobileServicesMenu?.classList.add('hidden');
      mobileServicesIcon?.classList.remove('rotate-180');
    } else {
      mobileIndustryMenu?.classList.add('hidden');
      mobileIndustryIcon?.classList.remove('rotate-180');
    }
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      if (!mobileMenu?.classList.contains('hidden')) {
        toggleMenu(true);
      }
      // Reset menus when nav closes
      mobileServicesMenu?.classList.add('hidden');
      mobileServicesIcon?.classList.remove('rotate-180');
      mobileProductsMenu?.classList.add('hidden');
      mobileProductsIcon?.classList.remove('rotate-180');
      mobileIndustryMenu?.classList.add('hidden');
      mobileIndustryIcon?.classList.remove('rotate-180');
    });
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !mobileMenu?.classList.contains('hidden')) {
      toggleMenu();
    }
  });
</script>
